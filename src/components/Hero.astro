---

---

<section class="hero">
  <!-- Full background topographic image -->
  <img
    src="/images/backgrounds/hero.png"
    alt=""
    class="hero__bg"
    aria-hidden="true"
  />

  <!-- Animated grid overlay -->
  <div class="hero__grid" aria-hidden="true"></div>

  <!-- Floating orbs / light spots -->
  <div class="hero__orbs" aria-hidden="true">
    <span class="hero__orb hero__orb--1"></span>
    <span class="hero__orb hero__orb--2"></span>
    <span class="hero__orb hero__orb--3"></span>
  </div>

  <!-- Scanning line -->
  <div class="hero__scan" aria-hidden="true"></div>

  <!-- Particles -->
  <div class="hero__particles" aria-hidden="true">
    <span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span>
  </div>
  <div class="hero__bg-overlay"></div>

  <div class="hero__inner container">
    <div class="hero__content">
      <div class="section-label hero__anim" style="--d: 0ms">
        Asset Integrity Management
      </div>
      <h1 class="hero__title">
        <span class="hero__anim text-light" style="--d: 80ms"
          >Trusted AIM System for</span
        ><br />
        <span class="hero__anim text-bold" style="--d: 160ms"
          >Asset-Intensive</span
        >
        <span class="hero__anim text-light" style="--d: 240ms">Industries.</span
        >
      </h1>
      <p class="hero__subtitle hero__anim" style="--d: 380ms">
        Enhancing reliability, reducing risk, and maximizing performance across
        the asset lifecycle.
      </p>
      <div class="hero__ctas hero__anim" style="--d: 480ms">
        <a href="#contact" class="btn btn-primary">Book a Demo</a>
        <a href="#products" class="btn btn-outline">
          Explore Products
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path
              d="M6 4L10 8L6 12"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="hero__visual">
      <!-- Main Dashboard Card -->
      <div class="dash hero__anim" style="--d: 400ms">
        <div class="dash__chrome">
          <div class="dash__dots">
            <span></span><span></span><span></span>
          </div>
          <div class="dash__url">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
              <rect
                x="2"
                y="4"
                width="6"
                height="5"
                rx="1"
                stroke="currentColor"
                stroke-width="1"></rect>
              <path
                d="M4 4V3a1 1 0 012 0v1"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"></path>
            </svg>
            visions.metegrity.io
          </div>
          <div class="dash__chrome-actions">
            <span class="dash__status">
              <span class="dash__status-dot"></span>
              SYNCED
            </span>
          </div>
        </div>

        <div class="dash__body">
          <!-- Sidebar nav -->
          <aside class="dash__nav">
            <span
              class="dash__nav-item dash__nav-item--active"
              title="Dashboard"
            >
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <rect
                  x="2"
                  y="2"
                  width="5"
                  height="5"
                  rx="1"
                  stroke="currentColor"
                  stroke-width="1.4"></rect>
                <rect
                  x="9"
                  y="2"
                  width="5"
                  height="5"
                  rx="1"
                  stroke="currentColor"
                  stroke-width="1.4"></rect>
                <rect
                  x="2"
                  y="9"
                  width="5"
                  height="5"
                  rx="1"
                  stroke="currentColor"
                  stroke-width="1.4"></rect>
                <rect
                  x="9"
                  y="9"
                  width="5"
                  height="5"
                  rx="1"
                  stroke="currentColor"
                  stroke-width="1.4"></rect>
              </svg>
            </span>
            <span class="dash__nav-item" title="Assets">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <path
                  d="M3 13V6l5-3 5 3v7"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"></path>
                <path
                  d="M3 13h10"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"></path>
              </svg>
            </span>
            <span class="dash__nav-item" title="RBI">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <circle
                  cx="8"
                  cy="8"
                  r="6"
                  stroke="currentColor"
                  stroke-width="1.4"></circle>
                <path
                  d="M8 4v4l3 2"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"></path>
              </svg>
            </span>
            <span class="dash__nav-item" title="Reports">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <path
                  d="M4 2h6l3 3v9H4V2z"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linejoin="round"></path>
                <path
                  d="M6 9h5M6 11h5"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"></path>
              </svg>
            </span>
            <span class="dash__nav-item" title="Alerts">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <path
                  d="M3 12h10l-2-2V7a3 3 0 00-6 0v3l-2 2z"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linejoin="round"></path>
                <circle cx="11" cy="4" r="2" fill="#FF6B00"></circle>
              </svg>
            </span>
          </aside>

          <!-- Main content -->
          <div class="dash__main">
            <div class="dash__header">
              <div>
                <span class="dash__eyebrow">Facility Overview</span>
                <h4 class="dash__heading">Asset Integrity</h4>
              </div>
              <div class="dash__tabs">
                <span class="dash__tab dash__tab--active">Overview</span>
                <span class="dash__tab">Risk</span>
                <span class="dash__tab">KPIs</span>
              </div>
            </div>

            <!-- KPI mini cards -->
            <div class="dash__kpis">
              <div class="dash__kpi">
                <span class="dash__kpi-label">Healthy Assets</span>
                <span class="dash__kpi-val"
                  ><span class="dc" data-to="94.3" data-dec="1">0.0</span
                  >%</span
                >
                <span class="dash__kpi-delta dash__kpi-delta--up">
                  <svg width="9" height="9" viewBox="0 0 10 10" fill="none"
                    ><path d="M5 2l3 4H2l3-4z" fill="currentColor"></path></svg
                  >
                  +2.1%
                </span>
              </div>
              <div class="dash__kpi">
                <span class="dash__kpi-label">Open NCRs</span>
                <span class="dash__kpi-val"
                  ><span class="dc" data-to="23">0</span></span
                >
                <span class="dash__kpi-delta dash__kpi-delta--down">
                  <svg width="9" height="9" viewBox="0 0 10 10" fill="none"
                    ><path d="M5 8L2 4h6L5 8z" fill="currentColor"></path></svg
                  >
                  -4 this wk
                </span>
              </div>
              <div class="dash__kpi">
                <span class="dash__kpi-label">Inspections</span>
                <span class="dash__kpi-val"
                  ><span class="dc" data-to="1247">0</span></span
                >
                <span class="dash__kpi-delta">YTD</span>
              </div>
            </div>

            <!-- Chart -->
            <div class="dash__chart">
              <div class="dash__chart-head">
                <span class="dash__chart-title"
                  >Integrity Trend · 12 Months</span
                >
                <span class="dash__chart-legend">
                  <span class="dash__legend"
                    ><span class="dash__dot dash__dot--orange"
                    ></span>Health</span
                  >
                  <span class="dash__legend"
                    ><span class="dash__dot dash__dot--dark"></span>Risk</span
                  >
                </span>
              </div>
              <svg
                class="dash__chart-svg"
                viewBox="0 0 380 120"
                preserveAspectRatio="none"
              >
                <!-- Grid -->
                <g stroke="#E8E8E8" stroke-width="0.5">
                  <line x1="0" y1="30" x2="380" y2="30"></line>
                  <line x1="0" y1="60" x2="380" y2="60"></line>
                  <line x1="0" y1="90" x2="380" y2="90"></line>
                </g>
                <!-- Area fill -->
                <path
                  class="dash__area"
                  d="M0 90 L32 72 L64 78 L96 60 L128 52 L160 58 L192 42 L224 48 L256 34 L288 40 L320 26 L352 22 L380 18 L380 120 L0 120 Z"
                  fill="url(#areaGrad)"
                  opacity="0.3"></path>
                <!-- Main line -->
                <path
                  class="dash__line"
                  d="M0 90 L32 72 L64 78 L96 60 L128 52 L160 58 L192 42 L224 48 L256 34 L288 40 L320 26 L352 22 L380 18"
                  stroke="#FF6B00"
                  stroke-width="2"
                  fill="none"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <!-- Secondary line -->
                <path
                  class="dash__line dash__line--2"
                  d="M0 100 L32 94 L64 88 L96 90 L128 82 L160 86 L192 76 L224 74 L256 70 L288 74 L320 66 L352 62 L380 58"
                  stroke="#1A1A1A"
                  stroke-width="1.5"
                  fill="none"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  opacity="0.5"
                  stroke-dasharray="3 3"></path>
                <!-- Point highlight -->
                <circle
                  cx="320"
                  cy="26"
                  r="4"
                  fill="#FF6B00"
                  class="dash__point"></circle>
                <circle
                  cx="320"
                  cy="26"
                  r="4"
                  fill="#FF6B00"
                  class="dash__point-ring"></circle>
                <defs>
                  <linearGradient id="areaGrad" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="#FF6B00" stop-opacity="0.4"
                    ></stop>
                    <stop offset="100%" stop-color="#FF6B00" stop-opacity="0"
                    ></stop>
                  </linearGradient>
                </defs>
              </svg>
            </div>

            <!-- Activity rows -->
            <div class="dash__rows">
              <div class="dash__row">
                <span class="dash__row-pill dash__row-pill--ok">OK</span>
                <span class="dash__row-name">Pipe Segment P-4721</span>
                <span class="dash__row-bar"><span style="--w: 92%"></span></span
                >
                <span class="dash__row-val">92%</span>
              </div>
              <div class="dash__row">
                <span class="dash__row-pill dash__row-pill--warn">WARN</span>
                <span class="dash__row-name">Vessel V-012</span>
                <span class="dash__row-bar"
                  ><span style="--w: 68%; --bg: #F97C00"></span></span
                >
                <span class="dash__row-val">68%</span>
              </div>
              <div class="dash__row">
                <span class="dash__row-pill dash__row-pill--ok">OK</span>
                <span class="dash__row-name">Heat Exchanger HX-3</span>
                <span class="dash__row-bar"><span style="--w: 87%"></span></span
                >
                <span class="dash__row-val">87%</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating card: RBI Alert (Proven Results style) -->
      <div class="stat-card stat-card--alert hero__anim" style="--d: 700ms">
        <div class="stat-card__header">
          <span class="stat-card__badge">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
              <path
                d="M5 1v4M5 7h.01"
                stroke="#FF6B00"
                stroke-width="1.4"
                stroke-linecap="round"></path>
              <circle cx="5" cy="5" r="4" stroke="#FF6B00" stroke-width="1.2"
              ></circle>
            </svg>
            RBI Alert
          </span>
          <span class="stat-card__live">
            <span class="stat-card__dot"></span>
            Live
          </span>
        </div>
        <div class="stat-card__val">
          Pressure<em> · V-012</em>
        </div>
        <div class="stat-card__lbl">Anomaly detected</div>
        <div class="stat-card__sub">Probability of Failure · High</div>
      </div>

      <!-- Floating card: Live Thickness sensor (Proven Results style) -->
      <div class="stat-card stat-card--sensor hero__anim" style="--d: 850ms">
        <div class="stat-card__header">
          <span class="stat-card__badge">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
              <path
                d="M1 7L3 5L5 6L9 2"
                stroke="#FF6B00"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            Sensor
          </span>
          <span class="stat-card__live">
            <span class="stat-card__dot"></span>
            Live
          </span>
        </div>
        <div class="stat-card__val">
          <span class="dc" data-to="12.48" data-dec="2">0.00</span><em>mm</em>
        </div>
        <div class="stat-card__lbl">Wall Thickness</div>
        <div class="stat-card__sub">Ultrasonic · Zone 4-B</div>
      </div>

      <!-- Floating card: Uptime stats (Proven Results style) -->
      <div class="stat-card stat-card--stats hero__anim" style="--d: 1000ms">
        <div class="stat-card__header">
          <span class="stat-card__badge">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
              <path
                d="M1 9L4 6L6 7L9 2"
                stroke="#FF6B00"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            Proven Results
          </span>
          <span class="stat-card__live">
            <span class="stat-card__dot"></span>
            Live
          </span>
        </div>
        <div class="stat-card__grid">
          <div class="stat-card__item">
            <span class="stat-card__val">1,350<em>+</em></span>
            <span class="stat-card__lbl">Facilities</span>
          </div>
          <div class="stat-card__vsep"></div>
          <div class="stat-card__item">
            <span class="stat-card__val">$1<em>T+</em></span>
            <span class="stat-card__lbl">Assets</span>
          </div>
        </div>
      </div>

      <!-- Decorative pulse ring -->
      <div class="hero__pulse" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--space-24);
    padding-bottom: var(--space-16);
    position: relative;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: -5%;
    width: 110%;
    height: 110%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
    animation: bg-drift 30s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes bg-drift {
    0%   { transform: scale(1.06) translate(0, 0); }
    25%  { transform: scale(1.08) translate(-1.5%, -0.8%); }
    50%  { transform: scale(1.05) translate(1%, -1.2%); }
    75%  { transform: scale(1.07) translate(1.5%, 0.6%); }
    100% { transform: scale(1.06) translate(0, 0); }
  }

  /* Animated grid overlay */
  .hero__grid {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(26, 26, 26, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26, 26, 26, 0.05) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%);
    animation: grid-pan 40s linear infinite;
  }

  @keyframes grid-pan {
    from { background-position: 0 0; }
    to   { background-position: 80px 80px; }
  }

  /* Orbs — colored light spots floating */
  .hero__orbs {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.55;
    will-change: transform;
  }

  .hero__orb--1 {
    width: 380px;
    height: 380px;
    top: -10%;
    left: -8%;
    background: radial-gradient(circle, rgba(255, 107, 0, 0.35), transparent 70%);
    animation: orb-float-1 18s ease-in-out infinite;
  }

  .hero__orb--2 {
    width: 460px;
    height: 460px;
    bottom: -15%;
    right: -10%;
    background: radial-gradient(circle, rgba(255, 138, 51, 0.25), transparent 70%);
    animation: orb-float-2 22s ease-in-out infinite;
  }

  .hero__orb--3 {
    width: 280px;
    height: 280px;
    top: 40%;
    left: 55%;
    background: radial-gradient(circle, rgba(255, 107, 0, 0.15), transparent 70%);
    animation: orb-float-3 26s ease-in-out infinite;
  }

  @keyframes orb-float-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(60px, 40px) scale(1.15); }
    66%      { transform: translate(-40px, 80px) scale(0.95); }
  }

  @keyframes orb-float-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-80px, -60px) scale(1.1); }
  }

  @keyframes orb-float-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25%      { transform: translate(-50px, 30px) scale(1.2); }
    50%      { transform: translate(40px, -50px) scale(0.9); }
    75%      { transform: translate(30px, 60px) scale(1.05); }
  }

  /* Horizontal scanning line */
  .hero__scan {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .hero__scan::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 107, 0, 0.4) 30%,
      rgba(255, 107, 0, 0.7) 50%,
      rgba(255, 107, 0, 0.4) 70%,
      transparent 100%);
    filter: blur(1px);
    animation: scan-line 8s linear infinite;
    opacity: 0.5;
  }

  @keyframes scan-line {
    0%   { top: -5%; opacity: 0; }
    10%  { opacity: 0.6; }
    90%  { opacity: 0.6; }
    100% { top: 105%; opacity: 0; }
  }

  /* Drifting particles */
  .hero__particles {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .hero__particles span {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0;
    box-shadow: 0 0 10px rgba(255, 107, 0, 0.7);
  }

  .hero__particles span:nth-child(1) { left: 10%; animation: particle-rise 12s linear infinite 0s; }
  .hero__particles span:nth-child(2) { left: 22%; animation: particle-rise 15s linear infinite 2s; }
  .hero__particles span:nth-child(3) { left: 35%; animation: particle-rise 10s linear infinite 4s; }
  .hero__particles span:nth-child(4) { left: 48%; animation: particle-rise 14s linear infinite 1s; }
  .hero__particles span:nth-child(5) { left: 60%; animation: particle-rise 13s linear infinite 3s; }
  .hero__particles span:nth-child(6) { left: 72%; animation: particle-rise 11s linear infinite 5s; }
  .hero__particles span:nth-child(7) { left: 84%; animation: particle-rise 16s linear infinite 0s; }
  .hero__particles span:nth-child(8) { left: 92%; animation: particle-rise 12s linear infinite 2.5s; }

  @keyframes particle-rise {
    0%   { top: 100%; opacity: 0; transform: translateX(0); }
    10%  { opacity: 0.7; }
    50%  { transform: translateX(30px); }
    90%  { opacity: 0.7; }
    100% { top: -5%; opacity: 0; transform: translateX(-20px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__bg,
    .hero__grid,
    .hero__orb,
    .hero__scan::before,
    .hero__particles span {
      animation: none !important;
    }
  }

  .hero__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(248, 246, 247, 0.7) 0%,
      rgba(248, 246, 247, 0.4) 50%,
      rgba(248, 246, 247, 0.15) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  /* Entrance animations */
  .hero__anim {
    opacity: 0;
    translate: 0 24px;
    animation: hero-in 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--d, 0ms);
  }

  @keyframes hero-in {
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  .hero__title {
    font-size: var(--font-size-hero);
    line-height: 1.05;
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
  }

  .hero__title .hero__anim {
    display: inline-block;
  }

  .hero__subtitle {
    font-size: var(--font-size-lg);
    max-width: 480px;
    margin-bottom: var(--space-10);
    line-height: 1.6;
  }

  .hero__ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero__visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 520px;
  }

  /* Decorative pulse ring behind dashboard */
  .hero__pulse {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 280px;
    height: 280px;
    margin-left: -140px;
    margin-top: -140px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 107, 0, 0.12) 0%,
      transparent 65%
    );
    z-index: 0;
    animation: hero-pulse 5s ease-in-out infinite;
  }

  @keyframes hero-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.7;
    }
    50% {
      transform: scale(1.15);
      opacity: 1;
    }
  }

  /* === DASHBOARD === */
  .dash {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 560px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: var(--radius-xl);
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.12),
      0 4px 16px rgba(0, 0, 0, 0.04);
    overflow: hidden;
    animation-delay: var(--d);
  }

  .dash {
    animation: hero-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) var(--d) forwards;
  }

  .dash__chrome {
