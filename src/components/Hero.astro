---
---

<section class="hero">
  <!-- Full background topographic image -->
  <img src="/images/backgrounds/hero.png" alt="" class="hero__bg" aria-hidden="true" />
  <div class="hero__bg-overlay"></div>

  <div class="hero__inner container">
    <div class="hero__content">
      <div class="section-label">Asset Integrity Management</div>
      <h1 class="hero__title">
        <span class="text-light">Trusted AIM System for</span><br />
        <span class="text-bold">Asset-Intensive</span>
        <span class="text-light">Industries.</span>
      </h1>
      <p class="hero__subtitle">
        Enhancing reliability, reducing risk, and maximizing performance across the asset lifecycle.
      </p>
      <div class="hero__ctas">
        <a href="#contact" class="btn btn-primary">Book a Demo</a>
        <a href="#products" class="btn btn-outline">
          Explore Products
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="hero__visual">
      <!-- Offshore platform isometric illustration -->
      <svg class="hero__platform" viewBox="0 0 520 580" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Water / Sea surface -->
        <path d="M0 420 Q60 410 130 420 Q200 430 260 420 Q330 410 400 420 Q460 430 520 420 V580 H0 Z" fill="rgba(26,26,26,0.04)" stroke="rgba(26,26,26,0.08)" stroke-width="0.5"/>
        <path d="M0 430 Q70 422 140 430 Q210 438 280 430 Q350 422 420 430 Q470 436 520 430" stroke="rgba(26,26,26,0.06)" stroke-width="0.5" fill="none"/>

        <!-- Platform legs going into water -->
        <g stroke="#1A1A1A" stroke-width="1.2">
          <line x1="160" y1="350" x2="140" y2="520"/>
          <line x1="360" y1="350" x2="380" y2="520"/>
          <line x1="220" y1="350" x2="210" y2="520"/>
          <line x1="300" y1="350" x2="310" y2="520"/>
          <!-- Cross bracing underwater -->
          <line x1="145" y1="440" x2="215" y2="480" opacity="0.3"/>
          <line x1="215" y1="440" x2="145" y2="480" opacity="0.3"/>
          <line x1="305" y1="440" x2="375" y2="480" opacity="0.3"/>
          <line x1="375" y1="440" x2="305" y2="480" opacity="0.3"/>
        </g>

        <!-- Main platform deck -->
        <g stroke="#1A1A1A" stroke-width="1.2">
          <!-- Deck base -->
          <path d="M130 350 H390 V360 H130 Z" fill="rgba(26,26,26,0.03)"/>
          <rect x="130" y="340" width="260" height="12" rx="1" fill="rgba(26,26,26,0.05)" stroke="#1A1A1A" stroke-width="1"/>

          <!-- Deck floor details -->
          <line x1="150" y1="345" x2="370" y2="345" opacity="0.3" stroke-dasharray="4 3"/>
        </g>

        <!-- Living quarters block (left) -->
        <g stroke="#1A1A1A" stroke-width="1">
          <rect x="140" y="280" width="80" height="60" rx="2" fill="rgba(26,26,26,0.03)"/>
          <rect x="140" y="270" width="80" height="12" rx="1" fill="rgba(26,26,26,0.04)"/>
          <!-- Windows -->
          <rect x="150" y="290" width="10" height="8" rx="1" fill="rgba(255,107,0,0.12)" stroke="#FF6B00" stroke-width="0.5"/>
          <rect x="165" y="290" width="10" height="8" rx="1" fill="rgba(255,107,0,0.12)" stroke="#FF6B00" stroke-width="0.5"/>
          <rect x="180" y="290" width="10" height="8" rx="1" fill="rgba(255,107,0,0.12)" stroke="#FF6B00" stroke-width="0.5"/>
          <rect x="195" y="290" width="10" height="8" rx="1" fill="rgba(255,107,0,0.12)" stroke="#FF6B00" stroke-width="0.5"/>
          <rect x="150" y="310" width="10" height="8" rx="1" fill="rgba(255,107,0,0.08)" stroke="#FF6B00" stroke-width="0.5"/>
          <rect x="165" y="310" width="10" height="8" rx="1" fill="rgba(255,107,0,0.08)" stroke="#FF6B00" stroke-width="0.5"/>
          <rect x="180" y="310" width="10" height="8" rx="1" fill="rgba(255,107,0,0.08)" stroke="#FF6B00" stroke-width="0.5"/>
          <rect x="195" y="310" width="10" height="8" rx="1" fill="rgba(255,107,0,0.08)" stroke="#FF6B00" stroke-width="0.5"/>
        </g>

        <!-- Processing module (center) -->
        <g stroke="#1A1A1A" stroke-width="1">
          <rect x="235" y="295" width="60" height="45" rx="2" fill="rgba(26,26,26,0.03)"/>
          <!-- Pipes on processing module -->
          <line x1="245" y1="295" x2="245" y2="260" stroke-width="2.5" opacity="0.6"/>
          <line x1="265" y1="295" x2="265" y2="250" stroke-width="2.5" opacity="0.6"/>
          <line x1="285" y1="295" x2="285" y2="270" stroke-width="2" opacity="0.6"/>
          <!-- Pipe tops (valves) -->
          <circle cx="245" cy="258" r="4" fill="rgba(26,26,26,0.06)" stroke-width="0.8"/>
          <circle cx="265" cy="248" r="5" fill="rgba(26,26,26,0.06)" stroke-width="0.8"/>
          <circle cx="285" cy="268" r="3.5" fill="rgba(26,26,26,0.06)" stroke-width="0.8"/>
          <!-- Horizontal pipe connections -->
          <line x1="245" y1="275" x2="285" y2="275" stroke-width="1.5" opacity="0.4"/>
        </g>

        <!-- Derrick / Drilling tower (right side - main feature) -->
        <g stroke="#1A1A1A" stroke-width="1">
          <!-- Tower base -->
          <rect x="320" y="310" width="50" height="30" rx="1" fill="rgba(26,26,26,0.04)"/>
          <!-- Tower structure -->
          <line x1="330" y1="310" x2="338" y2="120"/>
          <line x1="360" y1="310" x2="352" y2="120"/>
          <!-- Crown block -->
          <rect x="334" y="115" width="22" height="10" rx="1" fill="rgba(26,26,26,0.05)"/>
          <!-- Cross bracing -->
          <line x1="331" y1="290" x2="359" y2="270" opacity="0.5"/>
          <line x1="359" y1="290" x2="331" y2="270" opacity="0.5"/>
          <line x1="332" y1="260" x2="358" y2="240" opacity="0.5"/>
          <line x1="358" y1="260" x2="332" y2="240" opacity="0.5"/>
          <line x1="333" y1="230" x2="357" y2="210" opacity="0.5"/>
          <line x1="357" y1="230" x2="333" y2="210" opacity="0.5"/>
          <line x1="334" y1="200" x2="356" y2="180" opacity="0.5"/>
          <line x1="356" y1="200" x2="334" y2="180" opacity="0.5"/>
          <line x1="335" y1="170" x2="355" y2="150" opacity="0.5"/>
          <line x1="355" y1="170" x2="335" y2="150" opacity="0.5"/>
          <line x1="336" y1="145" x2="354" y2="130" opacity="0.5"/>
          <line x1="354" y1="145" x2="336" y2="130" opacity="0.5"/>
          <!-- Horizontal girts -->
          <line x1="331" y1="270" x2="359" y2="270" opacity="0.4"/>
          <line x1="332" y1="240" x2="358" y2="240" opacity="0.4"/>
          <line x1="333" y1="210" x2="357" y2="210" opacity="0.4"/>
          <line x1="334" y1="180" x2="356" y2="180" opacity="0.4"/>
          <line x1="335" y1="150" x2="355" y2="150" opacity="0.4"/>
          <!-- Drill string -->
          <line x1="345" y1="125" x2="345" y2="380" stroke-width="1.5" stroke-dasharray="6 3" opacity="0.3"/>
        </g>

        <!-- Flare boom (extending right) -->
        <g stroke="#1A1A1A" stroke-width="1">
          <line x1="385" y1="320" x2="480" y2="240"/>
          <line x1="385" y1="325" x2="460" y2="260"/>
          <!-- Cross bracing on flare boom -->
          <line x1="400" y1="312" x2="410" y2="302" opacity="0.4"/>
          <line x1="420" y1="298" x2="430" y2="288" opacity="0.4"/>
          <line x1="440" y1="280" x2="450" y2="270" opacity="0.4"/>
          <!-- Flare flame -->
          <path d="M478 238 Q485 220 480 210 Q490 215 488 228 Q495 218 490 208 Q498 215 492 232 Q486 242 478 238Z" fill="#FF6B00" opacity="0.7"/>
          <path d="M480 235 Q484 225 482 218 Q488 222 486 230Z" fill="#FF8A33" opacity="0.5"/>
        </g>

        <!-- Crane (left side) -->
        <g stroke="#1A1A1A" stroke-width="1" opacity="0.7">
          <line x1="155" y1="270" x2="155" y2="230"/>
          <line x1="155" y1="230" x2="100" y2="250"/>
          <line x1="155" y1="235" x2="110" y2="252"/>
          <!-- Cable -->
          <line x1="108" y1="250" x2="108" y2="280" stroke-dasharray="2 2" opacity="0.5"/>
          <!-- Hook -->
          <path d="M105 278 Q108 285 111 278" stroke-width="1" fill="none" opacity="0.5"/>
        </g>

        <!-- Helipad -->
        <g stroke="#1A1A1A" stroke-width="0.8" opacity="0.5">
          <circle cx="175" cy="265" r="12" fill="rgba(26,26,26,0.02)"/>
          <text x="171" y="269" font-size="10" font-weight="600" fill="#1A1A1A" opacity="0.4" font-family="sans-serif">H</text>
        </g>

        <!-- Small annotation labels -->
        <g font-family="'Outfit', sans-serif" font-size="8" fill="#707070">
          <text x="320" y="108" font-weight="500" opacity="0.6">DERRICK</text>
          <text x="460" y="206" font-weight="500" opacity="0.6">FLARE</text>
          <text x="140" y="264" font-weight="500" opacity="0.6">QUARTERS</text>
          <text x="242" y="244" font-weight="500" opacity="0.6">PROCESS</text>
        </g>
      </svg>

      <!-- Glass card overlay with stats -->
      <div class="hero__glass-card glass-card">
        <div class="hero__glass-stat">
          <span class="hero__glass-number">1,350+</span>
          <span class="hero__glass-label">Facilities Worldwide</span>
        </div>
        <div class="hero__glass-divider"></div>
        <div class="hero__glass-stat">
          <span class="hero__glass-number">$1T+</span>
          <span class="hero__glass-label">Managed Assets</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--space-20);
    padding-bottom: var(--space-16);
    position: relative;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
  }

  .hero__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(248, 246, 247, 0.6) 0%,
      rgba(248, 246, 247, 0.3) 50%,
      rgba(248, 246, 247, 0.1) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .hero__title {
    font-size: var(--font-size-hero);
    line-height: 1.05;
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
  }

  .hero__subtitle {
    font-size: var(--font-size-lg);
    max-width: 480px;
    margin-bottom: var(--space-10);
    line-height: 1.6;
  }

  .hero__ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero__visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__platform {
    width: 100%;
    max-width: 520px;
    height: auto;
    filter: drop-shadow(0 4px 20px rgba(0,0,0,0.04));
  }

  .hero__glass-card {
    position: absolute;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-5) var(--space-8);
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    animation: float 6s ease-in-out infinite;
    white-space: nowrap;
  }

  @keyframes float {
    0%, 100% { transform: translateX(-50%) translateY(0px); }
    50% { transform: translateX(-50%) translateY(-8px); }
  }

  .hero__glass-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .hero__glass-number {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    line-height: 1;
  }

  .hero__glass-label {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    font-weight: var(--font-medium);
  }

  .hero__glass-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .hero {
      min-height: auto;
      padding-top: var(--space-32);
    }

    .hero__title {
      font-size: var(--font-size-4xl);
    }

    .hero__platform {
      max-width: 360px;
    }

    .hero__glass-card {
      position: relative;
      bottom: auto;
      left: auto;
      transform: none;
      margin-top: var(--space-4);
      animation: floatMobile 6s ease-in-out infinite;
    }

    @keyframes floatMobile {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-6px); }
    }
  }
</style>
