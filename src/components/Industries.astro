---
const industries = [
  {
    name: 'Oil & Gas',
    description: 'Upstream, midstream, and downstream operations. RBI studies, corrosion management, and comprehensive data management.',
    features: ['Upstream Operations', 'Midstream Pipelines', 'Downstream Refining'],
    image: '/images/industries/oil-gas.png',
  },
  {
    name: 'Chemical & Petrochemical',
    description: 'Maximize production uptime with advanced corrosion management and regular inspection scheduling across facilities.',
    features: ['Corrosion Management', 'Inspection Scheduling', 'Compliance Tracking'],
    image: '/images/industries/chemical.png',
  },
  {
    name: 'Power & Energy',
    description: 'From biofuels to power generation, pulp and paper, and mining — solutions for diverse industrial integrity challenges.',
    features: ['Biofuels', 'Power Generation', 'Mining & Pulp'],
    image: '/images/industries/power-energy.png',
  },
];
---

<section class="industries section" id="industries">
  <!-- Right illustration: offshore platform -->
  <div class="industries__bg-right">
    <svg viewBox="0 0 350 550" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g stroke="#1A1A1A" stroke-width="1">
        <!-- Legs -->
        <line x1="100" y1="200" x2="80" y2="520" opacity="0.12"/>
        <line x1="250" y1="200" x2="270" y2="520" opacity="0.12"/>
        <line x1="175" y1="200" x2="175" y2="520" opacity="0.12"/>
        <!-- Cross bracing -->
        <line x1="85" y1="320" x2="175" y2="380" opacity="0.08"/>
        <line x1="175" y1="320" x2="85" y2="380" opacity="0.08"/>
        <line x1="175" y1="320" x2="265" y2="380" opacity="0.08"/>
        <line x1="265" y1="320" x2="175" y2="380" opacity="0.08"/>
        <line x1="87" y1="420" x2="175" y2="470" opacity="0.06"/>
        <line x1="175" y1="420" x2="87" y2="470" opacity="0.06"/>
        <line x1="175" y1="420" x2="263" y2="470" opacity="0.06"/>
        <line x1="263" y1="420" x2="175" y2="470" opacity="0.06"/>
        <!-- Deck -->
        <rect x="70" y="188" width="210" height="16" rx="2" opacity="0.12"/>
        <!-- Quarters -->
        <rect x="85" y="128" width="80" height="60" rx="3" opacity="0.1"/>
        <!-- Windows -->
        <rect x="95" y="140" width="8" height="6" rx="1" fill="#FF6B00" opacity="0.1" class="iso-sensor"/>
        <rect x="108" y="140" width="8" height="6" rx="1" fill="#FF6B00" opacity="0.1" class="iso-sensor"/>
        <rect x="121" y="140" width="8" height="6" rx="1" fill="#FF6B00" opacity="0.1" class="iso-sensor"/>
        <rect x="138" y="140" width="8" height="6" rx="1" fill="#FF6B00" opacity="0.08"/>
        <rect x="95" y="155" width="8" height="6" rx="1" fill="#FF6B00" opacity="0.07"/>
        <rect x="108" y="155" width="8" height="6" rx="1" fill="#FF6B00" opacity="0.07"/>
        <rect x="121" y="155" width="8" height="6" rx="1" fill="#FF6B00" opacity="0.07"/>
        <rect x="138" y="155" width="8" height="6" rx="1" fill="#FF6B00" opacity="0.06"/>
        <!-- Derrick -->
        <line x1="195" y1="188" x2="202" y2="30" opacity="0.12"/>
        <line x1="245" y1="188" x2="238" y2="30" opacity="0.12"/>
        <rect x="198" y="24" width="44" height="10" rx="2" opacity="0.1"/>
        <!-- Cross bracing on derrick -->
        <line x1="197" y1="165" x2="243" y2="148" opacity="0.07"/>
        <line x1="243" y1="165" x2="197" y2="148" opacity="0.07"/>
        <line x1="198" y1="130" x2="242" y2="113" opacity="0.07"/>
        <line x1="242" y1="130" x2="198" y2="113" opacity="0.07"/>
        <line x1="199" y1="95" x2="241" y2="78" opacity="0.07"/>
        <line x1="241" y1="95" x2="199" y2="78" opacity="0.07"/>
        <line x1="200" y1="65" x2="240" y2="50" opacity="0.07"/>
        <line x1="240" y1="65" x2="200" y2="50" opacity="0.07"/>
        <!-- Horizontal girts -->
        <line x1="197" y1="148" x2="243" y2="148" opacity="0.06"/>
        <line x1="198" y1="113" x2="242" y2="113" opacity="0.06"/>
        <line x1="199" y1="78" x2="241" y2="78" opacity="0.06"/>
        <!-- Flare -->
        <line x1="275" y1="180" x2="330" y2="110" opacity="0.1"/>
        <path d="M328 108 Q334 90 330 82 Q340 90 336 104Z" fill="#FF6B00" opacity="0.08" class="iso-flame"/>
        <!-- Drill string -->
        <line x1="220" y1="34" x2="220" y2="280" stroke-dasharray="5 4" opacity="0.06"/>
        <!-- Sensors -->
        <circle cx="120" cy="150" r="3" fill="#FF6B00" opacity="0.1" class="iso-sensor"/>
        <circle cx="220" cy="110" r="3" fill="#FF6B00" opacity="0.1" class="iso-sensor"/>
      </g>
    </svg>
  </div>

  <div class="container">
    <div class="industries__header reveal">
      <div class="section-label">Industries</div>
      <h2>
        <span class="text-light">Powering Asset Integrity Across</span><br />
        <span class="text-bold">Critical Industries.</span>
      </h2>
    </div>

    <div class="industries__grid">
      {industries.map((ind, i) => (
        <article class="industries__card reveal" style={`transition-delay: ${i * 120}ms`}>
          <div class="industries__card-image">
            <img src={ind.image} alt={ind.name} loading="lazy" />
            <!-- Overlay isometric per card -->
            {i === 0 && (
              <svg class="industries__card-svg" viewBox="0 0 300 200" fill="none">
                <g stroke="#FFF" stroke-width="0.8" opacity="0.35">
                  <line x1="150" y1="20" x2="150" y2="180"/>
                  <line x1="120" y1="40" x2="180" y2="40"/>
                  <line x1="115" y1="55" x2="185" y2="55"/>
                  <line x1="115" y1="55" x2="115" y2="160"/>
                  <line x1="185" y1="55" x2="185" y2="160"/>
                  <line x1="105" y1="160" x2="195" y2="160"/>
                  <line x1="115" y1="90" x2="185" y2="90"/>
                  <line x1="115" y1="125" x2="185" y2="125"/>
                  <line x1="115" y1="55" x2="185" y2="90" opacity="0.5"/>
                  <line x1="185" y1="55" x2="115" y2="90" opacity="0.5"/>
                  <line x1="115" y1="90" x2="185" y2="125" opacity="0.5"/>
                  <line x1="185" y1="90" x2="115" y2="125" opacity="0.5"/>
                </g>
              </svg>
            )}
            {i === 1 && (
              <svg class="industries__card-svg" viewBox="0 0 300 200" fill="none">
                <g stroke="#FFF" stroke-width="0.8" opacity="0.35">
                  <rect x="100" y="40" width="100" height="130" rx="50" fill="none"/>
                  <line x1="150" y1="25" x2="150" y2="100" opacity="0.4"/>
                  <line x1="125" y1="100" x2="175" y2="100" opacity="0.5"/>
                  <line x1="130" y1="120" x2="170" y2="120" opacity="0.5"/>
                  <circle cx="150" cy="80" r="8" opacity="0.3"/>
                  <rect x="210" y="50" width="50" height="15" rx="7" fill="none"/>
                  <line x1="200" y1="60" x2="210" y2="60" opacity="0.4"/>
                  <line x1="150" y1="170" x2="150" y2="190" opacity="0.4"/>
                  <rect x="140" y="185" width="20" height="12" rx="2" fill="none" opacity="0.3"/>
                </g>
              </svg>
            )}
            {i === 2 && (
              <svg class="industries__card-svg" viewBox="0 0 300 200" fill="none">
                <g stroke="#FFF" stroke-width="0.8" opacity="0.35">
                  <rect x="40" y="50" width="70" height="120" rx="3" fill="none"/>
                  <ellipse cx="170" cy="100" rx="30" ry="30" fill="none"/>
                  <line x1="110" y1="80" x2="140" y2="80" stroke-width="1.5" opacity="0.4"/>
                  <line x1="200" y1="100" x2="240" y2="100" stroke-width="1.5" opacity="0.4"/>
                  <rect x="240" y="82" width="35" height="36" rx="3" fill="none"/>
                  <circle cx="257" cy="100" r="10" fill="none" opacity="0.3"/>
                  <path d="M255 94 L253 100 L257 98 L255 106" stroke="#FFF" stroke-width="0.8" fill="none" opacity="0.5"/>
                </g>
              </svg>
            )}
          </div>

          <div class="industries__card-content">
            <div class="industries__card-accent"></div>
            <h3 class="industries__name">{ind.name}</h3>
            <p class="industries__desc">{ind.description}</p>
            <ul class="industries__features">
              {ind.features.map(f => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7L6 10L11 4" stroke="#FF6B00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .industries {
    position: relative;
    overflow: hidden;
  }

  .industries__bg-right {
    position: absolute;
    top: 15%;
    right: -60px;
    width: 480px;
    height: 80%;
    pointer-events: none;
    z-index: 0;
  }

  .industries__bg-right svg {
    width: 100%;
    height: 100%;
    animation: iso-drift-r 16s ease-in-out infinite;
  }

  @keyframes iso-drift-r {
    0%, 100% { transform: scaleX(-1) translateY(0) translateX(0); }
    50% { transform: scaleX(-1) translateY(-8px) translateX(4px); }
  }

  /* Sensor pulse */
  .iso-sensor {
    transform-origin: center;
    transform-box: fill-box;
    animation: iso-pulse 2.4s ease-in-out infinite;
  }

  .iso-sensor:nth-of-type(2n) {
    animation-delay: 0.6s;
  }

  .iso-sensor:nth-of-type(3n) {
    animation-delay: 1.2s;
  }

  @keyframes iso-pulse {
    0%, 100% {
      opacity: 0.1;
      transform: scale(1);
    }
    50% {
      opacity: 0.35;
      transform: scale(1.6);
    }
  }

  /* Flare flame flicker */
  .iso-flame {
    transform-origin: bottom center;
    transform-box: fill-box;
    animation: iso-flame 1.2s ease-in-out infinite;
  }

  @keyframes iso-flame {
    0%, 100% { transform: scaleY(1) scaleX(1); opacity: 0.08; }
    33% { transform: scaleY(1.25) scaleX(0.92); opacity: 0.18; }
    66% { transform: scaleY(0.9) scaleX(1.08); opacity: 0.12; }
  }

  /* Tank level rising */
  .iso-level {
    transform-origin: bottom center;
    transform-box: fill-box;
    animation: iso-level 4s ease-in-out infinite;
  }

  @keyframes iso-level {
    0%, 100% { transform: scaleY(0.6); opacity: 0.1; }
    50% { transform: scaleY(1); opacity: 0.2; }
  }

  @media (prefers-reduced-motion: reduce) {
    .industries__bg-right svg,
    .iso-sensor,
    .iso-flame,
    .iso-level {
      animation: none;
    }
  }

  @media (max-width: 1400px) {
    .industries__bg-right {
      right: -100px;
    }
  }

  @media (max-width: 900px) {
    .industries__bg-right {
      display: none;
    }
  }

  .industries .container {
    position: relative;
    z-index: 1;
  }

  .industries__header {
    max-width: 600px;
    margin-bottom: var(--space-16);
  }

  .industries__header h2 {
    margin-bottom: var(--space-4);
  }

  .industries__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .industries__card {
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
  }

  .industries__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .industries__card-image {
    position: relative;
    height: 220px;
    overflow: hidden;
  }

  .industries__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .industries__card:hover .industries__card-image img {
    transform: scale(1.05);
  }

  .industries__card-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .industries__card-content {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
    position: relative;
  }

  .industries__card-accent {
    position: absolute;
    top: 0;
    left: var(--space-6);
    right: var(--space-6);
    height: 3px;
    background: var(--color-primary);
    border-radius: 0 0 2px 2px;
  }

  .industries__name {
    font-size: var(--font-size-xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin-top: var(--space-2);
  }

  .industries__desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .industries__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .industries__features li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-dark);
    font-weight: var(--font-medium);
  }

  @media (max-width: 900px) {
    .industries__grid {
      grid-template-columns: 1fr;
      max-width: 450px;
    }
  }
</style>
