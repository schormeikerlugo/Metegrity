---
import Navbar from '../Navbar.astro';
import Footer from '../Footer.astro';

interface RelatedItem {
  title: string;
  href: string;
  image: string;
  meta?: string;
}

interface Props {
  type: string;
  title: string;
  description?: string;
  image: string;
  date?: string;
  readTime?: string;
  tag?: string;
  downloadable?: boolean;
  backHref?: string;
  backLabel?: string;
  related?: RelatedItem[];
}

const {
  type,
  title,
  description,
  image,
  date,
  readTime,
  tag,
  downloadable = false,
  backHref = '/insights',
  backLabel = 'Insights',
  related = [],
} = Astro.props;
---

<Navbar />
<main>
  <article class="article">
    <!-- Hero -->
    <div class="article__hero">
      <img src="/images/backgrounds/hero.png" alt="" class="article__hero-bg" aria-hidden="true" />
      <div class="article__hero-overlay"></div>
      <div class="container article__hero-inner">

        <!-- Back button -->
        <a href={backHref} class="article__back">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M12 8H4M4 8L8 4M4 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Back to {backLabel}</span>
        </a>

        <div class="article__hero-meta">
          <span class="article__type">{type}</span>
          {tag && <span class="article__tag">{tag}</span>}
        </div>
        <h1 class="article__title">{title}</h1>
        {description && <p class="article__excerpt">{description}</p>}
        <div class="article__info">
          {date && <span>{date}</span>}
          {readTime && <><span class="article__sep">·</span><span>{readTime}</span></>}
        </div>
        {downloadable && (
          <a href="#" class="btn btn-primary article__download" onclick="this.textContent='Coming soon...'; return false;">
            Download Free
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M8 2v10M4 8l4 4 4-4M3 14h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        )}
      </div>
    </div>

    <!-- Featured image -->
    <div class="article__image-wrap">
      <div class="container">
        <div class="article__image">
          <img src={image} alt={title} />
        </div>
      </div>
    </div>

    <!-- Content body -->
    <div class="article__body">
      <div class="container">
        <div class="article__content">
          <slot />
        </div>
      </div>
    </div>

    <!-- Related content -->
    {related.length > 0 && (
      <section class="article__related">
        <div class="container">
          <div class="article__related-header">
            <h2>More in <span class="text-primary">{backLabel}</span></h2>
            <a href={backHref} class="article__related-all">
              View all
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
          <div class="article__related-grid">
            {related.map(item => (
              <a href={item.href} class="article__related-card">
                <div class="article__related-image">
                  <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                </div>
                <div class="article__related-content">
                  <h3>{item.title}</h3>
                  {item.meta && <span class="article__related-meta">{item.meta}</span>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA bottom -->
    <section class="article__cta">
      <div class="container article__cta-inner">
        <h2>Want to learn more?</h2>
        <p>Schedule a demo or explore our product suite to see how Metegrity can transform your integrity program.</p>
        <div class="article__cta-actions">
          <a href="/book-a-demo" class="btn btn-primary">Book a Demo</a>
          <a href="/insights" class="btn btn-outline">More Insights</a>
        </div>
      </div>
    </section>
  </article>
</main>
<Footer />

<style>
  .article__hero {
    position: relative;
    padding: calc(var(--space-32) + var(--space-8)) 0 var(--space-12);
    overflow: hidden;
  }

  .article__hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    z-index: 0;
  }

  .article__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(248,246,247,0.85) 0%, rgba(248,246,247,0.95) 100%);
    z-index: 1;
  }

  .article__hero-inner {
    position: relative;
    z-index: 2;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Back button */
  .article__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4) var(--space-2) var(--space-3);
    margin-bottom: var(--space-6);
    font-size: var(--font-size-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text-secondary);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    transition: all var(--transition-base);
  }

  .article__back svg {
    transition: transform var(--transition-fast);
  }

  .article__back:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: rgba(255, 107, 0, 0.04);
    transform: translateX(-4px);
  }

  .article__back:hover svg {
    transform: translateX(-3px);
  }

  .article__hero-meta {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .article__type {
    padding: 4px 12px;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 10px;
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-sm);
  }

  .article__tag {
    padding: 4px 12px;
    background: rgba(255, 107, 0, 0.1);
    color: var(--color-primary);
    font-size: 10px;
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-sm);
  }

  .article__title {
    font-size: var(--font-size-5xl);
    font-weight: var(--font-bold);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-5);
    color: var(--color-dark);
  }

  .article__excerpt {
    font-size: var(--font-size-lg);
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 680px;
    margin-bottom: var(--space-5);
  }

  .article__info {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-weight: var(--font-medium);
    margin-bottom: var(--space-4);
  }

  .article__sep { opacity: 0.4; }

  .article__download { margin-top: var(--space-2); }

  .article__image-wrap {
    margin-top: calc(-1 * var(--space-4));
    position: relative;
    z-index: 3;
  }

  .article__image {
    max-width: 900px;
    margin: 0 auto;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.12);
  }

  .article__image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .article__body {
    padding: var(--space-16) 0;
  }

  .article__content {
    max-width: 900px;
    margin: 0 auto;
    font-size: var(--font-size-md);
    line-height: 1.8;
    color: var(--color-text-secondary);
    text-align: justify;
  }

  .article__content :global(h2) {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin: var(--space-10) 0 var(--space-5);
    letter-spacing: -0.01em;
    text-align: left;
  }

  .article__content :global(h3) {
    font-size: var(--font-size-lg);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin: var(--space-8) 0 var(--space-3);
    text-align: left;
  }

  .article__content :global(p) {
    margin-bottom: var(--space-5);
  }

  .article__content :global(ul),
  .article__content :global(ol) {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }

  .article__content :global(li) {
    margin-bottom: var(--space-2);
  }

  .article__content :global(strong) {
    color: var(--color-dark);
    font-weight: var(--font-semibold);
  }

  .article__content :global(a) {
    color: var(--color-primary);
    font-weight: var(--font-semibold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article__content :global(ul),
  .article__content :global(ol),
  .article__content :global(blockquote) {
    text-align: left;
  }

  .article__content :global(blockquote) {
    padding: var(--space-5) var(--space-6);
    margin: var(--space-6) 0;
    border-left: 3px solid var(--color-primary);
    background: rgba(255, 107, 0, 0.04);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: var(--color-dark);
  }

  /* Related content */
  .article__related {
    padding: var(--space-16) 0;
    background: var(--color-bg-alt);
  }

  .article__related-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-8);
  }

  .article__related-header h2 {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
  }

  .article__related-all {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    transition: gap var(--transition-fast);
  }

  .article__related-all:hover {
    gap: var(--space-3);
  }

  .article__related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .article__related-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
  }

  .article__related-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 32px rgba(0,0,0,0.08);
    border-color: rgba(255, 107, 0, 0.25);
  }

  .article__related-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .article__related-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .article__related-card:hover .article__related-image img {
    transform: scale(1.04);
  }

  .article__related-content {
    padding: var(--space-5);
  }

  .article__related-content h3 {
    font-size: var(--font-size-md);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    line-height: 1.35;
    margin-bottom: var(--space-2);
  }

  .article__related-meta {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    font-weight: var(--font-medium);
  }

  /* CTA */
  .article__cta {
    padding: var(--space-20) 0;
    background: var(--color-dark);
    color: var(--color-white);
  }

  .article__cta-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .article__cta h2 {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-4);
  }

  .article__cta p {
    color: rgba(255,255,255,0.6);
    margin-bottom: var(--space-8);
  }

  .article__cta-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .article__cta .btn-outline {
    color: var(--color-white);
    border-color: rgba(255,255,255,0.25);
  }

  @media (max-width: 900px) {
    .article__related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .article__title { font-size: var(--font-size-3xl); }
    .article__related-header {
      flex-direction: column;
      gap: var(--space-3);
      align-items: flex-start;
    }
  }
</style>
