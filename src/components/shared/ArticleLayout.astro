---
import Navbar from '../Navbar.astro';
import Footer from '../Footer.astro';

interface Props {
  type: string;
  title: string;
  description?: string;
  image: string;
  date?: string;
  readTime?: string;
  tag?: string;
  downloadable?: boolean;
}

const { type, title, description, image, date, readTime, tag, downloadable = false } = Astro.props;
---

<Navbar />
<main>
  <article class="article">
    <!-- Hero -->
    <div class="article__hero">
      <img src="/images/backgrounds/hero.png" alt="" class="article__hero-bg" aria-hidden="true" />
      <div class="article__hero-overlay"></div>
      <div class="container article__hero-inner">
        <div class="article__hero-meta">
          <span class="article__type">{type}</span>
          {tag && <span class="article__tag">{tag}</span>}
        </div>
        <h1 class="article__title">{title}</h1>
        {description && <p class="article__excerpt">{description}</p>}
        <div class="article__info">
          {date && <span>{date}</span>}
          {readTime && <><span class="article__sep">·</span><span>{readTime}</span></>}
        </div>
        {downloadable && (
          <a href="#" class="btn btn-primary article__download" onclick="event.preventDefault(); alert('Download will be available soon.')">
            Download Free
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M8 2v10M4 8l4 4 4-4M3 14h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        )}
      </div>
    </div>

    <!-- Featured image -->
    <div class="article__image-wrap">
      <div class="container">
        <div class="article__image">
          <img src={image} alt={title} />
        </div>
      </div>
    </div>

    <!-- Content body -->
    <div class="article__body">
      <div class="container">
        <div class="article__content">
          <slot />
        </div>
      </div>
    </div>

    <!-- CTA bottom -->
    <section class="article__cta">
      <div class="container article__cta-inner">
        <h2>Want to learn more?</h2>
        <p>Schedule a demo or explore our product suite to see how Metegrity can transform your integrity program.</p>
        <div class="article__cta-actions">
          <a href="/book-a-demo" class="btn btn-primary">Book a Demo</a>
          <a href="/insights" class="btn btn-outline">More Insights</a>
        </div>
      </div>
    </section>
  </article>
</main>
<Footer />

<style>
  .article__hero {
    position: relative;
    padding: calc(var(--space-32) + var(--space-8)) 0 var(--space-12);
    overflow: hidden;
  }

  .article__hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    z-index: 0;
  }

  .article__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(248,246,247,0.85) 0%, rgba(248,246,247,0.95) 100%);
    z-index: 1;
  }

  .article__hero-inner {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .article__hero-meta {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .article__type {
    padding: 4px 12px;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 10px;
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-sm);
  }

  .article__tag {
    padding: 4px 12px;
    background: rgba(255, 107, 0, 0.1);
    color: var(--color-primary);
    font-size: 10px;
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-sm);
  }

  .article__title {
    font-size: var(--font-size-5xl);
    font-weight: var(--font-bold);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-5);
    color: var(--color-dark);
  }

  .article__excerpt {
    font-size: var(--font-size-lg);
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 680px;
    margin-bottom: var(--space-5);
  }

  .article__info {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-weight: var(--font-medium);
    margin-bottom: var(--space-4);
  }

  .article__sep { opacity: 0.4; }

  .article__download { margin-top: var(--space-2); }

  .article__image-wrap {
    margin-top: calc(-1 * var(--space-4));
    position: relative;
    z-index: 3;
  }

  .article__image {
    max-width: 900px;
    margin: 0 auto;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.12);
  }

  .article__image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .article__body {
    padding: var(--space-16) 0;
  }

  .article__content {
    max-width: 760px;
    margin: 0 auto;
    font-size: var(--font-size-md);
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .article__content :global(h2) {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin: var(--space-10) 0 var(--space-5);
    letter-spacing: -0.01em;
  }

  .article__content :global(h3) {
    font-size: var(--font-size-lg);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin: var(--space-8) 0 var(--space-3);
  }

  .article__content :global(p) {
    margin-bottom: var(--space-5);
  }

  .article__content :global(ul),
  .article__content :global(ol) {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }

  .article__content :global(li) {
    margin-bottom: var(--space-2);
  }

  .article__content :global(strong) {
    color: var(--color-dark);
    font-weight: var(--font-semibold);
  }

  .article__content :global(a) {
    color: var(--color-primary);
    font-weight: var(--font-semibold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article__content :global(blockquote) {
    padding: var(--space-5) var(--space-6);
    margin: var(--space-6) 0;
    border-left: 3px solid var(--color-primary);
    background: rgba(255, 107, 0, 0.04);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: var(--color-dark);
  }

  .article__cta {
    padding: var(--space-20) 0;
    background: var(--color-dark);
    color: var(--color-white);
  }

  .article__cta-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .article__cta h2 {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-4);
  }

  .article__cta p {
    color: rgba(255,255,255,0.6);
    margin-bottom: var(--space-8);
  }

  .article__cta-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .article__cta .btn-outline {
    color: var(--color-white);
    border-color: rgba(255,255,255,0.25);
  }

  @media (max-width: 768px) {
    .article__title { font-size: var(--font-size-3xl); }
    .article__hero-inner, .article__content { text-align: left; }
  }
</style>
