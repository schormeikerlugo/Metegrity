---
interface Props {
  type?: string;
  title: string;
  description?: string;
  image: string;
  meta?: string;
  href?: string;
  tag?: string;
  featured?: boolean;
  compact?: boolean;
}

const {
  type = 'Article',
  title,
  description,
  image,
  meta,
  href = '#',
  tag,
  featured = false,
  compact = false,
} = Astro.props;
---

<a href={href} class={`rcard ${featured ? 'rcard--featured' : ''} ${compact ? 'rcard--compact' : ''}`}>
  <div class="rcard__image">
    <img src={image} alt={title} loading="lazy" />
    {tag && <span class="rcard__tag">{tag}</span>}
  </div>
  <div class="rcard__content">
    <span class="rcard__type">{type}</span>
    <h3 class="rcard__title">{title}</h3>
    {description && <p class="rcard__desc">{description}</p>}
    <div class="rcard__footer">
      {meta && <span class="rcard__meta">{meta}</span>}
      <span class="rcard__arrow">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  .rcard {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all var(--transition-base);
    text-decoration: none;
    color: inherit;
  }

  .rcard:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    border-color: rgba(255, 107, 0, 0.25);
  }

  .rcard__image {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .rcard__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 6s ease;
  }

  .rcard:hover .rcard__image img {
    transform: scale(1.06);
  }

  .rcard__tag {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    padding: 4px 10px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-size: 10px;
    font-weight: var(--font-bold);
    color: var(--color-dark);
    border-radius: var(--radius-sm);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .rcard__content {
    padding: var(--space-5) var(--space-6) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .rcard__type {
    font-size: 10px;
    font-weight: var(--font-bold);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .rcard__title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .rcard__desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    flex: 1;
  }

  .rcard__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-3);
  }

  .rcard__meta {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    font-weight: var(--font-medium);
  }

  .rcard__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-bg-alt);
    color: var(--color-dark);
    transition: all var(--transition-fast);
  }

  .rcard:hover .rcard__arrow {
    background: var(--color-primary);
    color: var(--color-white);
    transform: translate(2px, -2px);
  }

  /* Featured variant */
  .rcard--featured {
    grid-column: span 2;
    flex-direction: row;
  }

  .rcard--featured .rcard__image {
    aspect-ratio: auto;
    flex: 1;
  }

  .rcard--featured .rcard__content {
    flex: 1;
    padding: var(--space-8);
    justify-content: center;
  }

  .rcard--featured .rcard__title {
    font-size: var(--font-size-2xl);
    line-height: 1.2;
  }

  /* Compact variant */
  .rcard--compact .rcard__image {
    aspect-ratio: 3 / 2;
  }

  .rcard--compact .rcard__content {
    padding: var(--space-4) var(--space-5);
  }

  .rcard--compact .rcard__title {
    font-size: var(--font-size-md);
  }

  @media (max-width: 900px) {
    .rcard--featured {
      grid-column: span 1;
      flex-direction: column;
    }
    .rcard--featured .rcard__image { aspect-ratio: 16 / 10; }
  }
</style>
