---
interface Props {
  titleLight?: string;
  titleBold?: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  titleLight = 'Ready to Transform',
  titleBold = 'Your Asset Integrity?',
  description = 'Schedule a personalized demo and discover how Metegrity can reduce risk and maximize performance across your operations.',
  primaryLabel = 'Book a Demo',
  primaryHref = '/contact',
  secondaryLabel = 'Contact Sales',
  secondaryHref = '/contact',
} = Astro.props;
---

<section class="cta-section">
  <div class="cta-section__bg" aria-hidden="true">
    <div class="cta-section__glow"></div>
  </div>
  <div class="container cta-section__inner">
    <h2 class="cta-section__title">
      <span class="text-light">{titleLight}</span><br />
      <span class="text-bold">{titleBold}</span>
    </h2>
    <p class="cta-section__desc">{description}</p>
    <div class="cta-section__actions">
      <a href={primaryHref} class="btn btn-primary">{primaryLabel}</a>
      <a href={secondaryHref} class="btn btn-outline cta-section__outline">{secondaryLabel}</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    padding: var(--space-24) 0;
    background: var(--color-dark);
    color: var(--color-white);
    overflow: hidden;
  }

  .cta-section__bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
  }

  .cta-section__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 700px;
    height: 700px;
    margin-left: -350px;
    margin-top: -350px;
    background: radial-gradient(circle, rgba(255, 107, 0, 0.2), transparent 60%);
    filter: blur(20px);
    animation: cta-pulse 6s ease-in-out infinite;
  }

  @keyframes cta-pulse {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.15); opacity: 1; }
  }

  .cta-section__inner {
    position: relative;
    text-align: center;
    z-index: 1;
  }

  .cta-section__title {
    font-size: var(--font-size-4xl);
    line-height: 1.1;
    margin-bottom: var(--space-5);
    letter-spacing: -0.02em;
  }

  .cta-section__title .text-light {
    color: rgba(255, 255, 255, 0.6);
  }

  .cta-section__desc {
    font-size: var(--font-size-md);
    color: rgba(255, 255, 255, 0.65);
    max-width: 560px;
    margin: 0 auto var(--space-8);
  }

  .cta-section__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-section__outline {
    background: transparent;
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .cta-section__outline::after {
    background: rgba(255, 255, 255, 0.1) !important;
  }

  .cta-section__outline:hover {
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.5);
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-section__glow { animation: none; }
  }
</style>
