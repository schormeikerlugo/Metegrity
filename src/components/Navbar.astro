---
const navLinks = [
  { label: 'Products', href: '#products', children: [
    { label: 'Visions Enterprise', href: '#' },
    { label: 'VISIONSGO', href: '#' },
    { label: 'Visions RBI Bundle', href: '#' },
    { label: 'Fugitive Emissions', href: '#' },
  ]},
  { label: 'Services', href: '#services' },
  { label: 'Industries', href: '#industries' },
  { label: 'Insights', href: '#' },
  { label: 'About', href: '#about' },
  { label: 'Contact', href: '#contact' },
];
---

<nav class="navbar" id="navbar">
  <div class="navbar__inner container">
    <a href="/" class="navbar__logo" aria-label="Metegrity">
      <img src="/images/brand/logo.png" alt="Metegrity" />
    </a>

    <ul class="navbar__links">
      {navLinks.map(link => (
        <li class="navbar__item">
          <a href={link.href} class="navbar__link">
            {link.label}
            {link.children && (
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M3 5L6 8L9 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
          </a>
          {link.children && (
            <div class="navbar__dropdown">
              {link.children.map(child => (
                <a href={child.href} class="navbar__dropdown-link">{child.label}</a>
              ))}
            </div>
          )}
        </li>
      ))}
    </ul>

    <div class="navbar__actions">
      <a href="#contact" class="btn btn-primary">Book a Demo</a>
    </div>

    <button class="navbar__toggle" id="navToggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="navbar__mobile" id="mobileMenu">
    <div class="navbar__mobile-inner">
      <ul class="navbar__mobile-links">
        {navLinks.map((link, i) => (
          <li style={`--i: ${i}`}><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
      <a href="#contact" class="btn btn-primary navbar__mobile-cta" style={`--i: ${navLinks.length}`}>Book a Demo</a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: var(--space-4) 0;
    transition: padding var(--transition-base), background var(--transition-base), border-color var(--transition-base);
  }

  .navbar.scrolled {
    background: rgba(248, 246, 247, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-3) 0;
  }

  /* When mobile menu is open, navbar keeps solid bg */
  .navbar.menu-open {
    background: var(--color-white);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom-color: transparent;
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .navbar__logo img {
    height: 20px;
    width: auto;
    object-fit: contain;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .navbar__item {
    position: relative;
  }

  .navbar__link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    font-weight: var(--font-medium);
    color: var(--color-dark-700);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .navbar__link:hover {
    color: var(--color-dark);
    background: rgba(0, 0, 0, 0.04);
  }

  .navbar__dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    padding: var(--space-2);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: all var(--transition-fast);
  }

  .navbar__item:hover .navbar__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(4px);
  }

  .navbar__dropdown-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--color-dark-700);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .navbar__dropdown-link:hover {
    background: rgba(255, 107, 0, 0.06);
    color: var(--color-primary);
  }

  .navbar__actions {
    flex-shrink: 0;
  }

  .navbar__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-2);
  }

  .navbar__toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-dark);
    border-radius: 2px;
    transition: all var(--transition-fast);
  }

  .navbar__toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .navbar__toggle.active span:nth-child(2) {
    opacity: 0;
  }
  .navbar__toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .navbar__mobile {
    max-height: 0;
    overflow: hidden;
    background: var(--color-white);
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .navbar__mobile.open {
    max-height: calc(100vh - 60px);
    border-top: 1px solid var(--color-border);
  }

  .navbar__mobile-inner {
    padding: var(--space-6) var(--container-padding);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .navbar__mobile-links {
    width: 100%;
    max-width: 400px;
  }

  .navbar__mobile-links li {
    opacity: 0;
    transform: translateY(-14px);
    transition:
      opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0ms;
  }

  .navbar__mobile.open .navbar__mobile-links li {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--i, 0) * 60ms + 120ms);
  }

  .navbar__mobile-links li a {
    display: block;
    padding: var(--space-3) 0;
    font-size: var(--font-size-md);
    font-weight: var(--font-medium);
    color: var(--color-dark);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-fast);
  }

  .navbar__mobile-links li a:hover {
    color: var(--color-primary);
  }

  .navbar__mobile-links li:last-child a {
    border-bottom: none;
  }

  .navbar__mobile-cta {
    width: 100%;
    max-width: 400px;
    margin-top: var(--space-4);
    opacity: 0;
    transform: translateY(-14px);
    transition:
      opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .navbar__mobile.open .navbar__mobile-cta {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--i, 0) * 60ms + 120ms);
  }

  @media (prefers-reduced-motion: reduce) {
    .navbar__mobile,
    .navbar__mobile-links li,
    .navbar__mobile-cta {
      transition: none !important;
      transform: none !important;
    }
  }

  @media (max-width: 900px) {
    .navbar__links,
    .navbar__actions {
      display: none;
    }
    .navbar__toggle {
      display: flex;
    }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('navToggle');
  const mobile = document.getElementById('mobileMenu');

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 40);
  });

  function closeMenu() {
    toggle?.classList.remove('active');
    mobile?.classList.remove('open');
    navbar?.classList.remove('menu-open');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    const isOpen = !mobile?.classList.contains('open');
    toggle.classList.toggle('active', isOpen);
    mobile?.classList.toggle('open', isOpen);
    navbar?.classList.toggle('menu-open', isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Close mobile menu on link click
  mobile?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', closeMenu);
  });

  // Close on ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobile?.classList.contains('open')) closeMenu();
  });
</script>
