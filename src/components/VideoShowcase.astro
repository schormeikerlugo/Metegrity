---
---

<section class="video-showcase" aria-label="Metegrity showcase video">
  <video
    class="video-showcase__video"
    data-src="/videos/showcase.mp4"
    autoplay
    muted
    loop
    playsinline
    preload="none"
    aria-hidden="true"
  ></video>
  <div class="video-showcase__overlay"></div>
</section>

<style>
  .video-showcase {
    position: relative;
    width: 100%;
    height: 456px;
    overflow: hidden;
    background: var(--color-dark);
  }

  .video-showcase__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-showcase__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(26, 26, 26, 0.15) 0%,
      rgba(26, 26, 26, 0.05) 50%,
      rgba(26, 26, 26, 0.2) 100%
    );
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .video-showcase {
      height: 320px;
    }
  }

  @media (max-width: 480px) {
    .video-showcase {
      height: 260px;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const video = document.querySelector<HTMLVideoElement>('.video-showcase__video');
    if (!video || video.src) return;
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const v = entry.target as HTMLVideoElement;
          v.src = v.dataset.src || '';
          v.load();
          io.unobserve(v);
        }
      });
    }, { rootMargin: '200px' });
    io.observe(video);
  });
</script>
