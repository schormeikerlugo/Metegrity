---
---

<section class="innovation section">
  <div class="container">
    <div class="innovation__inner">
      <div class="innovation__content reveal">
        <div class="section-label">Why Metegrity</div>
        <h2>
          <span class="text-light">Innovation That</span><br />
          <span class="text-bold">Drives Results.</span>
        </h2>
        <p class="innovation__text">
          Metegrity is a global leader in asset integrity management software. Innovation at Metegrity is more than a value — it's a strategic imperative. We drive meaningful change by collaborating closely with subject matter experts from our client base to guide and steer innovation that is both practical and impactful.
        </p>
        <p class="innovation__text">
          This co-innovation model enables smarter risk assessments, faster decision-making, and more proactive integrity strategies across high-stakes industries.
        </p>
        <a href="#" class="btn btn-outline" style="margin-top: var(--space-4);">
          Read More
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="innovation__visual reveal">
        <div class="innovation__image-wrap">
          <img src="/images/backgrounds/drives-results.png" alt="Innovation drives results" class="innovation__image" />
        </div>

        <!-- Results stats card (overlaps image bottom-left) -->
        <div class="innovation__stats">
          <div class="innovation__stats-header">
            <span class="innovation__stats-badge">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                <path d="M1 9L4 6L6 8L9 3" stroke="#FF6B00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Proven Results
            </span>
            <span class="innovation__stats-live">
              <span class="innovation__stats-dot"></span>
              Live
            </span>
          </div>

          <div class="innovation__stats-grid">
            <div class="innovation__stats-item">
              <span class="innovation__stats-val" data-animate="40-60">40-60<em>%</em></span>
              <span class="innovation__stats-lbl">Faster Deployment</span>
              <span class="innovation__stats-sub">vs. legacy AIM systems</span>
            </div>
            <div class="innovation__stats-sep"></div>
            <div class="innovation__stats-item">
              <span class="innovation__stats-val"><span data-count-to="99.9" data-decimals="1">0.0</span><em>%</em></span>
              <span class="innovation__stats-lbl">System Uptime</span>
              <span class="innovation__stats-sub">across 1,350+ facilities</span>
            </div>
          </div>

          <div class="innovation__stats-footer">
            <div class="innovation__stats-trust">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M6 1l1.5 3.5L11 5 8.5 7.5 9 11 6 9.5 3 11l.5-3.5L1 5l3.5-.5L6 1z" fill="#FF6B00" fill-opacity="0.2" stroke="#FF6B00" stroke-width="0.8"/>
              </svg>
              Trusted by Chevron, Marathon, and global leaders
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .innovation__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .innovation__content h2 {
    margin-bottom: var(--space-6);
  }

  .innovation__text {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-4);
    max-width: 500px;
  }

  .innovation__visual {
    position: relative;
  }

  .innovation__visual {
    position: relative;
    padding-bottom: var(--space-16);
  }

  .innovation__image-wrap {
    position: relative;
    width: 92%;
    margin-left: auto;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3.3;
  }

  .innovation__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-xl);
  }

  /* Results stats card — overlaps image */
  .innovation__stats {
    position: absolute;
    left: 0;
    bottom: 0;
    right: 18%;
    padding: var(--space-5) var(--space-6);
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: var(--radius-xl);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
    z-index: 2;
    animation: innovation-card-float 6s ease-in-out infinite;
  }

  @keyframes innovation-card-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .innovation__stats-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .innovation__stats-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: 4px 10px;
    background: rgba(255, 107, 0, 0.1);
    color: var(--color-primary);
    font-size: 10px;
    font-weight: var(--font-bold);
    border-radius: var(--radius-sm);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .innovation__stats-live {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 10px;
    font-weight: var(--font-semibold);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .innovation__stats-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22C55E;
    animation: stats-dot-pulse 2s ease-in-out infinite;
  }

  @keyframes stats-dot-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
    50% { box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
  }

  .innovation__stats-grid {
    display: flex;
    align-items: stretch;
    gap: var(--space-5);
    padding: var(--space-2) 0;
  }

  .innovation__stats-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .innovation__stats-val {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-extrabold);
    color: var(--color-dark);
    line-height: 1;
    letter-spacing: -0.02em;
    display: flex;
    align-items: baseline;
    gap: 2px;
  }

  .innovation__stats-val em {
    font-style: normal;
    font-size: 0.5em;
    font-weight: var(--font-bold);
    color: var(--color-primary);
  }

  .innovation__stats-lbl {
    font-size: var(--font-size-sm);
    color: var(--color-dark);
    font-weight: var(--font-semibold);
    margin-top: var(--space-1);
  }

  .innovation__stats-sub {
    font-size: 11px;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .innovation__stats-sep {
    width: 1px;
    background: var(--color-border);
  }

  .innovation__stats-footer {
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .innovation__stats-trust {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 11px;
    color: var(--color-text-secondary);
    font-weight: var(--font-medium);
  }

  @media (prefers-reduced-motion: reduce) {
    .innovation__stats,
    .innovation__stats-dot {
      animation: none;
    }
  }

  @media (max-width: 900px) {
    .innovation__inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
    .innovation__image-wrap {
      width: 100%;
    }
    .innovation__stats {
      position: relative;
      right: auto;
      bottom: auto;
      left: auto;
      margin-top: calc(-1 * var(--space-8));
      margin-left: var(--space-4);
      margin-right: var(--space-4);
    }
  }
</style>

<script>
  const counters = document.querySelectorAll<HTMLElement>('.innovation__stats [data-count-to]');
  if (counters.length) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const end = parseFloat(el.dataset.countTo || '0');
        const decimals = parseInt(el.dataset.decimals || '0', 10);
        const duration = 2000;
        const start = performance.now();
        function tick(now: number) {
          const p = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = (eased * end).toFixed(decimals);
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        io.unobserve(el);
      });
    }, { threshold: 0.5 });
    counters.forEach(c => io.observe(c));
  }
</script>
