<style>
  .innovation__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .innovation__content h2 {
    margin-bottom: var(--space-6);
  }

  .innovation__text {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-4);
    max-width: 500px;
  }

  .innovation__visual {
    position: relative;
  }

  .innovation__image-wrap {
    position: relative;
    background: rgba(248, 246, 247, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3.3;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
  }

  .innovation__illustration {
    width: 100%;
    height: auto;
  }

  .innovation__glass {
    position: absolute;
    bottom: var(--space-6);
    left: var(--space-6);
    right: var(--space-6);
    padding: var(--space-5) var(--space-6);
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.5);
  }

  .innovation__glass-row {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .innovation__glass-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 1;
  }

  .innovation__glass-val {
    font-size: var(--font-size-xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
  }

  .innovation__glass-lbl {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    font-weight: var(--font-medium);
  }

  .innovation__glass-sep {
    width: 1px;
    height: 36px;
    background: var(--color-border);
  }

  @media (max-width: 900px) {
    .innovation__inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
  }
</style>
