---
const capabilities = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="2" y="6" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><rect x="16" y="6" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><rect x="2" y="18" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 2"/><rect x="16" y="18" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 2"/></svg>`,
    title: 'Modular Architecture',
    description: 'Scalable widget architecture isolates critical KPIs on a single, unified command screen. Manage high data density with zero visual noise.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="1.5"/><path d="M14 6V14L20 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="14" cy="14" r="2" fill="currentColor"/></svg>`,
    title: 'Real-Time Monitoring',
    description: 'Instant anomaly detection and push notifications. Manage high data density with zero visual noise across your entire facility network.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 22L10 14L15 18L22 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="24" cy="6" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M4 6V22H26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: 'Proactive Analytics',
    description: 'Eliminate latency in critical decision-making. Correlate process and integrity data with instant alerts for operational anomalies.',
  },
];
---

<section class="capabilities section">
  <!-- Background isometric: pipeline network -->
  <div class="capabilities__bg">
    <svg viewBox="0 0 450 500" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g stroke="#FFFFFF" stroke-width="0.8">
        <!-- Separator vessel -->
        <rect x="30" y="60" width="120" height="45" rx="22" opacity="0.06"/>
        <line x1="30" y1="82" x2="10" y2="82" stroke-width="2" opacity="0.05"/>
        <line x1="150" y1="75" x2="180" y2="75" stroke-width="2" opacity="0.05"/>
        <line x1="150" y1="90" x2="180" y2="90" stroke-width="2" opacity="0.05"/>
        <!-- Compressor -->
        <circle cx="220" cy="82" r="28" opacity="0.06"/>
        <circle cx="220" cy="82" r="14" opacity="0.04"/>
        <line x1="248" y1="82" x2="290" y2="82" stroke-width="2" opacity="0.05"/>
        <!-- Vertical column -->
        <rect x="290" y="20" width="35" height="200" rx="17" opacity="0.06"/>
        <line x1="295" y1="60" x2="320" y2="60" opacity="0.03" stroke-dasharray="2 2"/>
        <line x1="295" y1="90" x2="320" y2="90" opacity="0.03" stroke-dasharray="2 2"/>
        <line x1="295" y1="120" x2="320" y2="120" opacity="0.03" stroke-dasharray="2 2"/>
        <line x1="295" y1="150" x2="320" y2="150" opacity="0.03" stroke-dasharray="2 2"/>
        <line x1="295" y1="180" x2="320" y2="180" opacity="0.03" stroke-dasharray="2 2"/>
        <line x1="307" y1="20" x2="307" y2="5" opacity="0.05"/>
        <ellipse cx="307" cy="3" rx="6" ry="3" opacity="0.04"/>
        <!-- Side draw pipes -->
        <line x1="325" y1="100" x2="380" y2="100" stroke-width="1.5" opacity="0.05"/>
        <line x1="325" y1="160" x2="380" y2="160" stroke-width="1.5" opacity="0.05"/>
        <!-- Heat exchangers -->
        <rect x="370" y="90" width="60" height="20" rx="10" opacity="0.05"/>
        <rect x="370" y="150" width="60" height="20" rx="10" opacity="0.05"/>
        <!-- Pipe rack horizontal -->
        <line x1="20" y1="250" x2="440" y2="250" stroke-width="1" opacity="0.04"/>
        <line x1="20" y1="255" x2="440" y2="255" stroke-width="0.5" opacity="0.03"/>
        <!-- Vertical drops from pipe rack -->
        <line x1="100" y1="105" x2="100" y2="250" stroke-width="1.5" opacity="0.04"/>
        <line x1="220" y1="110" x2="220" y2="250" stroke-width="1.5" opacity="0.04"/>
        <line x1="307" y1="220" x2="307" y2="250" stroke-width="1.5" opacity="0.04"/>
        <line x1="400" y1="170" x2="400" y2="250" stroke-width="1.5" opacity="0.04"/>
        <!-- Storage tanks below pipe rack -->
        <ellipse cx="100" cy="310" rx="40" ry="12" opacity="0.05"/>
        <rect x="60" y="310" width="80" height="65" opacity="0.04"/>
        <ellipse cx="100" cy="375" rx="40" ry="12" opacity="0.05"/>
        <line x1="100" y1="255" x2="100" y2="310" stroke-width="1.5" opacity="0.04"/>
        <!-- Second tank -->
        <ellipse cx="300" cy="310" rx="35" ry="10" opacity="0.05"/>
        <rect x="265" y="310" width="70" height="55" opacity="0.04"/>
        <ellipse cx="300" cy="365" rx="35" ry="10" opacity="0.05"/>
        <line x1="307" y1="255" x2="307" y2="310" stroke-width="1.5" opacity="0.04"/>
        <!-- Pump -->
        <rect x="180" y="400" width="22" height="14" rx="3" opacity="0.05"/>
        <circle cx="191" cy="407" r="5" opacity="0.04"/>
        <line x1="140" y1="375" x2="140" y2="407" stroke-width="1.5" opacity="0.04"/>
        <line x1="140" y1="407" x2="180" y2="407" stroke-width="1.5" opacity="0.04"/>
        <line x1="202" y1="407" x2="265" y2="407" stroke-width="1.5" opacity="0.04"/>
        <line x1="265" y1="407" x2="265" y2="365" stroke-width="1.5" opacity="0.04"/>
        <!-- Sensor dots -->
        <circle cx="90" cy="82" r="2.5" fill="#FFFFFF" opacity="0.06" class="cap-sensor"/>
        <circle cx="220" cy="82" r="2.5" fill="#FFFFFF" opacity="0.06" class="cap-sensor"/>
        <circle cx="307" cy="130" r="2.5" fill="#FFFFFF" opacity="0.06" class="cap-sensor"/>
        <circle cx="100" cy="340" r="2.5" fill="#FFFFFF" opacity="0.06" class="cap-sensor"/>
        <circle cx="300" cy="340" r="2.5" fill="#FFFFFF" opacity="0.06" class="cap-sensor"/>
      </g>
    </svg>
  </div>

  <div class="container">
    <div class="capabilities__header reveal">
      <div class="section-label">Core Capabilities</div>
      <h2>
        <span class="text-light">Precision Tools for</span><br />
        <span class="text-bold">High-Stakes Operations.</span>
      </h2>
    </div>

    <div class="capabilities__grid">
      {capabilities.map((cap, i) => (
        <div class="capabilities__item reveal" style={`transition-delay: ${i * 120}ms`}>
          <div class="capabilities__icon" set:html={cap.icon} />
          <h3 class="capabilities__title">{cap.title}</h3>
          <p class="capabilities__desc">{cap.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .capabilities {
    background: var(--color-dark);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }

  .capabilities__bg {
    position: absolute;
    right: 50px;
    top: 2%;
    width: 480px;
    height: 90%;
    pointer-events: none;
    z-index: 0;
  }

  .capabilities__bg svg {
    width: 100%;
    height: 100%;
    animation: cap-drift 18s ease-in-out infinite;
  }

  @keyframes cap-drift {
    0%, 100% { transform: translateY(0) translateX(0); }
    50% { transform: translateY(-12px) translateX(-6px); }
  }

  .cap-sensor {
    transform-origin: center;
    transform-box: fill-box;
    animation: cap-pulse 2.6s ease-in-out infinite;
  }

  .cap-sensor:nth-of-type(2n) { animation-delay: 0.5s; }
  .cap-sensor:nth-of-type(3n) { animation-delay: 1s; }
  .cap-sensor:nth-of-type(4n) { animation-delay: 1.5s; }

  @keyframes cap-pulse {
    0%, 100% {
      opacity: 0.06;
      transform: scale(1);
    }
    50% {
      opacity: 0.3;
      transform: scale(1.8);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .capabilities__bg svg,
    .cap-sensor {
      animation: none;
    }
  }

  .capabilities .container {
    position: relative;
    z-index: 1;
  }

  .capabilities::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 107, 0, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .capabilities .section-label {
    color: var(--color-primary);
  }

  .capabilities__header {
    max-width: 560px;
    margin-bottom: var(--space-16);
  }

  .capabilities__header h2 .text-light {
    color: var(--color-text-muted);
  }

  .capabilities__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .capabilities__item {
    padding: var(--space-8);
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
  }

  .capabilities__item:hover {
    border-color: rgba(255, 107, 0, 0.2);
    background: rgba(255, 255, 255, 0.07);
  }

  .capabilities__icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 107, 0, 0.1);
    border-radius: var(--radius-lg);
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  .capabilities__title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-3);
  }

  .capabilities__desc {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .capabilities__grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
