---
const stats = [
  { end: 30, prefix: '', suffix: '+', label: 'Years in the Industry' },
  { end: 1350, prefix: '', suffix: '+', label: 'Facilities Worldwide' },
  { end: 1, prefix: '$', suffix: 'T+', label: 'In Managed Assets' },
  { end: 5, prefix: '', suffix: '', label: 'Continents Served' },
];
---

<section class="stats">
  <div class="stats__inner container">
    {stats.map(stat => (
      <div class="stats__item reveal">
        <span
          class="stats__value"
          data-end={stat.end}
          data-prefix={stat.prefix}
          data-suffix={stat.suffix}
          data-animated="false"
        >
          {stat.prefix}{stat.end >= 1000 ? stat.end.toLocaleString('en-US') : stat.end}{stat.suffix}
        </span>
        <span class="stats__label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .stats {
    padding: var(--space-12) 0;
    background: #1A1A1A;
  }

  .stats__inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
    text-align: center;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .stats__value {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-extrabold);
    color: #FFFFFF;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stats__label {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.6);
    font-weight: var(--font-medium);
  }

  @media (max-width: 768px) {
    .stats__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8) var(--space-4);
    }
  }

  @media (max-width: 480px) {
    .stats__inner {
      grid-template-columns: 1fr 1fr;
    }
    .stats__value {
      font-size: var(--font-size-3xl);
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    function formatNumber(n: number): string {
      return n >= 1000 ? n.toLocaleString('en-US') : String(n);
    }

    function animateCounter(el: HTMLElement) {
      if (el.dataset.animated === 'true') return;
      el.dataset.animated = 'true';
      const end = Number(el.dataset.end);
      const prefix = el.dataset.prefix || '';
      const suffix = el.dataset.suffix || '';
      const duration = 1200;
      const startTime = performance.now();
      el.textContent = prefix + '0' + suffix;

      function update(now: number) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = prefix + formatNumber(Math.round(eased * end)) + suffix;
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }

    const els = document.querySelectorAll<HTMLElement>('.stats__value');
    if (!els.length) return;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounter(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    els.forEach(el => { el.dataset.animated = 'false'; observer.observe(el); });
  });
</script>
