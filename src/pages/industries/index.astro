---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/shared/PageHero.astro';
import CTASection from '../../components/shared/CTASection.astro';

const industries = [
  {
    name: 'Oil & Gas',
    tagline: 'Upstream · Midstream · Downstream',
    description: 'Purpose-built for the world\'s most demanding hydrocarbon operations. From offshore platforms to deepwater FPSOs and refining complexes — Metegrity powers asset integrity across the full value chain.',
    features: ['Offshore & onshore platforms', 'Pipelines & compressor stations', 'Refineries & terminals'],
    href: '/industries/oil-gas',
    image: '/images/industries/oil-gas.png',
    stats: [{ val: '800+', lbl: 'O&G Facilities' }, { val: '$850B+', lbl: 'Assets' }],
  },
  {
    name: 'Chemical & Petrochemical',
    tagline: 'Production · Safety · Compliance',
    description: 'Maintain production uptime and ensure safety across chemical processing facilities. Advanced corrosion management, damage mechanism libraries, and regulatory compliance built for process industries.',
    features: ['Corrosion management', 'Inspection scheduling', 'PSM compliance'],
    href: '/industries/chemical-petrochemical',
    image: '/images/industries/chemical.png',
    stats: [{ val: '400+', lbl: 'Chemical Sites' }, { val: '99.9%', lbl: 'Uptime' }],
  },
  {
    name: 'Power & Energy',
    tagline: 'Generation · Biofuels · Renewables',
    description: 'Adapt to the evolving energy landscape. From traditional power generation to biofuels, pulp and paper, and mining — our solutions scale to diverse industrial integrity challenges.',
    features: ['Power generation', 'Biofuels & renewables', 'Mining & pulp'],
    href: '/industries/other',
    image: '/images/industries/power-energy.png',
    stats: [{ val: '150+', lbl: 'Power Sites' }, { val: '5', lbl: 'Continents' }],
  },
];
---

<Layout title="Industries | Metegrity" description="Powering Asset Integrity Across Critical Industries — Oil & Gas, Chemical, Power and more.">
  <Navbar />
  <main>
    <PageHero
      eyebrow="Industries"
      titleLight="Powering Asset Integrity Across"
      titleBold="Critical Industries."
      description="Metegrity's AIM solutions are built for asset-intensive industries — helping you safeguard critical assets, boost reliability, and optimize performance where it matters most."
      align="center"
    />

    <section class="ind-list section">
      <div class="container">
        {industries.map((ind, i) => (
          <article class={`ind-list__item reveal ${i % 2 === 1 ? 'ind-list__item--reverse' : ''}`} style={`transition-delay: ${i * 80}ms`}>
            <div class="ind-list__visual">
              <img src={ind.image} alt={ind.name} loading="lazy" />
              <span class="ind-list__tag badge badge-primary">{ind.tagline}</span>
              <div class="ind-list__stats">
                {ind.stats.map(s => (
                  <div>
                    <span class="ind-list__stat-val">{s.val}</span>
                    <span class="ind-list__stat-lbl">{s.lbl}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="ind-list__content">
              <h2 class="ind-list__name">{ind.name}</h2>
              <p class="ind-list__desc">{ind.description}</p>
              <ul class="ind-list__features">
                {ind.features.map(f => (
                  <li>
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <circle cx="8" cy="8" r="7" stroke="#FF6B00" stroke-width="1.5"/>
                      <path d="M5 8L7 10L11 6" stroke="#FF6B00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a href={ind.href} class="btn btn-dark">
                Explore {ind.name}
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                  <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <CTASection
      titleLight="Your industry."
      titleBold="Our expertise."
      description="Not sure which solution fits best? Our integrity experts will tailor Metegrity to your unique operational challenges."
    />
  </main>
  <Footer />
</Layout>

<style>
  .ind-list__item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
    padding: var(--space-16) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .ind-list__item:last-child { border-bottom: none; }

  .ind-list__item--reverse { direction: rtl; }
  .ind-list__item--reverse .ind-list__content,
  .ind-list__item--reverse .ind-list__visual { direction: ltr; }

  .ind-list__visual {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.12);
  }

  .ind-list__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 6s ease;
  }

  .ind-list__item:hover .ind-list__visual img {
    transform: scale(1.04);
  }

  .ind-list__tag {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .ind-list__stats {
    position: absolute;
    bottom: var(--space-4);
    left: var(--space-4);
    right: var(--space-4);
    display: flex;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: var(--radius-md);
  }

  .ind-list__stats > div {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .ind-list__stat-val {
    font-size: var(--font-size-lg);
    font-weight: var(--font-extrabold);
    color: var(--color-dark);
    line-height: 1;
  }

  .ind-list__stat-lbl {
    font-size: 10px;
    color: var(--color-text-secondary);
    font-weight: var(--font-medium);
    margin-top: 2px;
  }

  .ind-list__name {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  .ind-list__desc {
    font-size: var(--font-size-md);
    line-height: 1.7;
    margin-bottom: var(--space-5);
    max-width: 480px;
  }

  .ind-list__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .ind-list__features li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--color-dark);
    font-weight: var(--font-medium);
  }

  @media (max-width: 900px) {
    .ind-list__item,
    .ind-list__item--reverse {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      direction: ltr;
      text-align: center;
    }
    .ind-list__desc { margin-left: auto; margin-right: auto; }
    .ind-list__features li { justify-content: center; }
    .ind-list__name { font-size: var(--font-size-2xl); }
  }
</style>
