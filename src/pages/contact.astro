<script>
  // Basic client-side validation feedback
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    const btn = form.querySelector('.contact-form__submit') as HTMLButtonElement;
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = 'Sending… <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5" stroke-dasharray="28" stroke-dashoffset="20" stroke-linecap="round"/></svg>';
      setTimeout(() => {
        btn.innerHTML = 'Message sent ✓';
        btn.style.background = '#028901';
        form.reset();
      }, 1200);
    }
  });
</script>
