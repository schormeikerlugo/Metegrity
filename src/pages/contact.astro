---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/shared/PageHero.astro';

const offices = [
  {
    country: 'Canada',
    flag: 'CA',
    company: 'Metegrity Inc.',
    address: '5715-76 Avenue, Edmonton, AB T6B 0A7',
    phone: '+1 780-485-8500',
    tollFree: '+1 866-485-8500',
    hq: true,
  },
  {
    country: 'United States',
    flag: 'US',
    company: 'Metegrity Corp.',
    address: 'Williams Tower, 2800 Post Oak Blvd., Suite 5600, Houston, TX 77056',
    phone: '+1 832-390-2262',
    tollFree: '+1 844-485-8500',
  },
  {
    country: 'Europe',
    flag: 'EU',
    company: 'Metegrity Sp. z.o.o.',
    address: 'ul. Swojczycka 129, 51-502 Wroclaw, Poland',
    phone: '+48-71-88-11-171',
  },
];

const channels = [
  {
    title: 'Sales Inquiries',
    description: 'New to Metegrity? Our sales team can help you evaluate fit and ROI.',
    email: 'sales@metegrity.com',
    cta: 'Book a Demo',
    href: '/book-a-demo',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 6h16v12H4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M4 6l8 7 8-7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Technical Support',
    description: 'Existing customers — our 24/7 support team is ready to help.',
    email: 'support@metegrity.com',
    cta: 'Open a Ticket',
    href: '#',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 3a9 9 0 00-9 9v5a2 2 0 002 2h2v-7H5v0a7 7 0 0114 0v0h-2v7h2a2 2 0 002-2v-5a9 9 0 00-9-9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Partnership',
    description: 'Explore co-marketing, integration, and reseller opportunities.',
    email: 'partners@metegrity.com',
    cta: 'Partner Program',
    href: '/about/partner-network',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="8" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/><circle cx="16" cy="16" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M12 12l-1.5 1.5M11.5 10.5L13 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Media & PR',
    description: 'Press inquiries, analyst briefings, and media kit requests.',
    email: 'press@metegrity.com',
    cta: 'Media Kit',
    href: '#',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 20h16l-2-8H6l-2 8zM8 12V8a4 4 0 018 0v4" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  },
];

const faqs = [
  {
    q: 'How quickly can I get a response?',
    a: 'Sales inquiries: within 1 business day. Support tickets (existing customers): within 4 hours. Partnership requests: within 2 business days.',
  },
  {
    q: 'Do you offer free trials?',
    a: 'We offer personalized demos and pilot deployments rather than generic free trials. Our solution is highly configurable, so a scoped pilot delivers more value than a trial.',
  },
  {
    q: 'What industries do you serve?',
    a: 'Oil & gas (upstream/midstream/downstream), chemical & petrochemical, power generation, mining, pulp & paper, and biofuels. Learn more in Industries.',
  },
  {
    q: 'Can you integrate with our existing systems?',
    a: 'Yes. Metegrity integrates bidirectionally with SAP, Oracle, Maximo, Infor, Esri GIS, Microsoft 365, and more. See Integrations.',
  },
];
---

<Layout title="Contact | Metegrity" description="Get in touch with Metegrity — sales, support, partnership, and global offices in Canada, USA, and Europe.">
  <Navbar />
  <main>
    <PageHero
      eyebrow="Contact"
      titleLight="Let's get"
      titleBold="in touch."
      description="Questions about products, services, partnerships, or careers? We'd love to hear from you. Response within 1 business day — guaranteed."
      align="center"
    />

    <!-- Main contact section -->
    <section class="contact-main section">
      <div class="container">
        <div class="contact-main__inner">

          <!-- Left: contact form -->
          <div class="contact-form reveal">
            <div class="contact-form__header">
              <h2>
                <span class="text-light">Send us a</span>
                <span class="text-bold">message.</span>
              </h2>
              <p>We'll route your inquiry to the right person and respond within 1 business day.</p>
            </div>

            <form class="contact-form__form" id="contactForm" novalidate>
              <div class="field-row">
                <label class="field">
                  <span class="field__label">Full Name <em>*</em></span>
                  <input type="text" name="name" placeholder="John Smith" required />
                </label>
                <label class="field">
                  <span class="field__label">Company <em>*</em></span>
                  <input type="text" name="company" placeholder="Acme Energy" required />
                </label>
              </div>

              <div class="field-row">
                <label class="field">
                  <span class="field__label">Work Email <em>*</em></span>
                  <input type="email" name="email" placeholder="john@acme.com" required />
                </label>
                <label class="field">
                  <span class="field__label">Phone</span>
                  <input type="tel" name="phone" placeholder="+1 555-0100" />
                </label>
              </div>

              <div class="field-row">
                <label class="field">
                  <span class="field__label">Your Role <em>*</em></span>
                  <select name="role" required>
                    <option value="">Select role…</option>
                    <option>Integrity Engineer / Inspector</option>
                    <option>Integrity Manager</option>
                    <option>Operations / Maintenance</option>
                    <option>IT / Digital Transformation</option>
                    <option>Executive / C-Suite</option>
                    <option>Consultant / Partner</option>
                    <option>Other</option>
                  </select>
                </label>
                <label class="field">
                  <span class="field__label">Inquiry Type <em>*</em></span>
                  <select name="type" required>
                    <option value="">Select inquiry type…</option>
                    <option>Product Demo</option>
                    <option>Pricing & Licensing</option>
                    <option>Technical Question</option>
                    <option>Partnership</option>
                    <option>Careers</option>
                    <option>Media / Press</option>
                    <option>Other</option>
                  </select>
                </label>
              </div>

              <label class="field">
                <span class="field__label">Message <em>*</em></span>
                <textarea name="message" placeholder="Tell us about your use case, timeline, or questions…" rows="6" required></textarea>
              </label>

              <label class="field field--check">
                <input type="checkbox" name="newsletter" />
                <span>Subscribe to our monthly newsletter with industry insights</span>
              </label>

              <div class="field field--check">
                <input type="checkbox" name="privacy" id="privacy" required />
                <label for="privacy"><span>I agree to Metegrity's <a href="#">Privacy Policy</a> and consent to being contacted regarding this inquiry <em>*</em></span></label>
              </div>

              <button type="submit" class="btn btn-primary contact-form__submit">
                Send Message
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                  <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>

              <p class="contact-form__note">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path d="M6 1l6 3v3c0 3-3 4-6 4s-6-1-6-4V4l6-3z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
                  <path d="M4 6l1.5 1.5L8 5" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
                </svg>
                Your information is secure and will never be shared with third parties.
              </p>
            </form>
          </div>

          <!-- Right: quick info -->
          <aside class="contact-aside">
            <div class="contact-aside__card reveal">
              <h3>Toll-free (US / CA)</h3>
              <a href="tel:+18664858500" class="contact-aside__number">+1 866-485-8500</a>
              <p>Monday — Friday, 8am-6pm MT</p>
            </div>

            <div class="contact-aside__card contact-aside__card--dark reveal" style="transition-delay: 100ms">
              <span class="contact-aside__tag">Fastest Path</span>
              <h3>Skip the form.</h3>
              <p>Ready to see Metegrity in action? Book a personalized 30-minute demo.</p>
              <a href="/book-a-demo" class="btn btn-primary">Book a Demo</a>
            </div>

            <div class="contact-aside__card reveal" style="transition-delay: 200ms">
              <h3>Existing customer?</h3>
              <p>Open a support ticket for the fastest response time.</p>
              <a href="#" class="contact-aside__link">
                Access Support Portal
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                  <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- Specific channels -->
    <section class="contact-channels">
      <div class="container">
        <div class="contact-channels__header reveal">
          <div class="section-label">Direct Channels</div>
          <h2>
            <span class="text-light">Reach the right</span>
            <span class="text-bold">team directly.</span>
          </h2>
        </div>
        <div class="contact-channels__grid">
          {channels.map((c, i) => (
            <div class="channel reveal" style={`transition-delay: ${i * 80}ms`}>
              <div class="channel__icon" set:html={c.icon} />
              <h3>{c.title}</h3>
              <p>{c.description}</p>
              <a href={`mailto:${c.email}`} class="channel__email">{c.email}</a>
              <a href={c.href} class="channel__cta">
                {c.cta}
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                  <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Global offices -->
    <section class="contact-offices section">
      <div class="container">
        <div class="contact-offices__header reveal">
          <div class="section-label">Global Offices</div>
          <h2>
            <span class="text-light">Three locations.</span>
            <span class="text-bold">One global mission.</span>
          </h2>
        </div>

        <div class="contact-offices__grid">
          {offices.map((o, i) => (
            <div class={`office ${o.hq ? 'office--hq' : ''} reveal`} style={`transition-delay: ${i * 80}ms`}>
              {o.hq && <span class="office__badge">Global HQ</span>}
              <div class="office__flag">{o.flag}</div>
              <h3>{o.country}</h3>
              <p class="office__company">{o.company}</p>

              <div class="office__detail">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M8 14s-5-4-5-8a5 5 0 0110 0c0 4-5 8-5 8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <circle cx="8" cy="6" r="2" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                <span>{o.address}</span>
              </div>

              <div class="office__detail">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M5.5 2L3 4.5C3 4.5 4 8 6 10C8 12 11.5 13 11.5 13L13 10.5L10.5 8.5L9 10C9 10 7.5 9.5 6 8C4.5 6.5 4 5 4 5L5.5 3.5L5.5 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
                <a href={`tel:${o.phone.replace(/\s|-/g, '')}`}>{o.phone}</a>
              </div>

              {o.tollFree && (
                <div class="office__detail">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M3 8h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                  <a href={`tel:${o.tollFree.replace(/\s|-/g, '')}`}>{o.tollFree} <em>toll-free</em></a>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="contact-faq">
      <div class="container">
        <div class="contact-faq__header reveal">
          <div class="section-label">FAQ</div>
          <h2>
            <span class="text-light">Common</span>
            <span class="text-bold">questions.</span>
          </h2>
        </div>
        <div class="contact-faq__list">
          {faqs.map((f, i) => (
            <details class="faq-item reveal" style={`transition-delay: ${i * 60}ms`}>
              <summary>
                <span>{f.q}</span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* Layout */
  .contact-main__inner {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  /* Form */
  .contact-form {
    padding: var(--space-8);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
  }

  .contact-form__header {
    margin-bottom: var(--space-8);
  }

  .contact-form__header h2 {
    margin-bottom: var(--space-3);
  }

  .contact-form__header p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .contact-form__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .field__label {
    font-size: var(--font-size-xs);
    font-weight: var(--font-semibold);
    color: var(--color-dark);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .field__label em {
    font-style: normal;
    color: var(--color-primary);
    margin-left: 2px;
  }

  .field input,
  .field select,
  .field textarea {
    padding: var(--space-3) var(--space-4);
    font-size: var(--font-size-sm);
    font-family: inherit;
    color: var(--color-dark);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--color-text-muted);
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background: var(--color-white);
    box-shadow: 0 0 0 3px rgba(255,107,0,0.12);
  }

  .field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .field--check {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .field--check input[type="checkbox"] {
    width: 18px;
    height: 18px;
    padding: 0;
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--color-primary);
    cursor: pointer;
  }

  .field--check span,
  .field--check label {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
    line-height: 1.5;
  }

  .field--check a {
    color: var(--color-primary);
    font-weight: var(--font-semibold);
  }

  .field--check em {
    color: var(--color-primary);
    font-style: normal;
  }

  .contact-form__submit {
    align-self: flex-start;
    margin-top: var(--space-2);
  }

  .contact-form__note {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Aside */
  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: sticky;
    top: 100px;
  }

  .contact-aside__card {
    padding: var(--space-6);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: all var(--transition-base);
  }

  .contact-aside__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
  }

  .contact-aside__card h3 {
    font-size: var(--font-size-md);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin-bottom: var(--space-2);
  }

  .contact-aside__card p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .contact-aside__card--dark {
    background: var(--color-dark);
    color: var(--color-white);
  }

  .contact-aside__card--dark h3 { color: var(--color-white); }
  .contact-aside__card--dark p { color: rgba(255,255,255,0.65); }

  .contact-aside__tag {
    display: inline-block;
    padding: 3px 8px;
    background: rgba(255, 107, 0, 0.15);
    color: var(--color-primary);
    font-size: 10px;
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-3);
  }

  .contact-aside__number {
    display: block;
    font-size: var(--font-size-2xl);
    font-weight: var(--font-extrabold);
    color: var(--color-primary);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .contact-aside__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    transition: gap var(--transition-fast);
  }

  .contact-aside__link:hover { gap: var(--space-3); }

  /* Channels */
  .contact-channels {
    padding: var(--space-20) 0;
    background: var(--color-bg-alt);
  }

  .contact-channels__header {
    max-width: 640px;
    margin: 0 auto var(--space-12);
    text-align: center;
  }

  .contact-channels__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  .channel {
    padding: var(--space-6);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .channel:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 107, 0, 0.25);
    box-shadow: 0 12px 28px rgba(0,0,0,0.08);
  }

  .channel__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 107, 0, 0.08);
    border-radius: var(--radius-md);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .channel h3 {
    font-size: var(--font-size-md);
    font-weight: var(--font-bold);
    color: var(--color-dark);
  }

  .channel p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    flex: 1;
  }

  .channel__email {
    font-size: var(--font-size-sm);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    margin-top: var(--space-1);
  }

  .channel__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: var(--font-semibold);
    color: var(--color-dark);
    padding-top: var(--space-3);
    margin-top: var(--space-2);
    border-top: 1px solid var(--color-border);
    transition: all var(--transition-fast);
  }

  .channel__cta:hover { color: var(--color-primary); gap: var(--space-3); }

  /* Offices */
  .contact-offices__header {
    max-width: 640px;
    margin: 0 auto var(--space-12);
    text-align: center;
  }

  .contact-offices__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .office {
    position: relative;
    padding: var(--space-8);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: all var(--transition-base);
  }

  .office:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 107, 0, 0.25);
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  }

  .office--hq {
    border-color: rgba(255, 107, 0, 0.4);
    background: linear-gradient(180deg, rgba(255, 107, 0, 0.03), transparent 40%);
  }

  .office__badge {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    padding: 4px 10px;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 10px;
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: var(--radius-sm);
  }

  .office__flag {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: var(--font-extrabold);
    color: var(--color-dark);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
  }

  .office h3 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin-bottom: var(--space-1);
  }

  .office__company {
    font-size: var(--font-size-sm);
    color: var(--color-primary);
