---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/shared/PageHero.astro';
import FeatureSplit from '../../components/shared/FeatureSplit.astro';
import FeatureGrid from '../../components/shared/FeatureGrid.astro';
import CTASection from '../../components/shared/CTASection.astro';

const timeline = [
  { year: '1992', title: 'The Beginning', description: 'Software conceptualized by an NDT/Engineering services company within the Lloyd\'s Register group.' },
  { year: '2000s', title: 'Industry Adoption', description: 'Visions becomes the AIM system of choice for major operators worldwide. First deployments at Chevron, Marathon, and others.' },
  { year: '2010', title: 'Metegrity Founded', description: 'Software division spun off to form Metegrity as an independent company focused on asset integrity.' },
  { year: 'Today', title: 'Global Leader', description: '1,350+ facilities across 5 continents. $1T+ in managed assets. 30+ years of industry leadership.' },
];

const values = [
  {
    title: 'Client Partnership',
    description: 'Our solutions embody the collective experience and best practices of our client partners. Co-innovation is core to who we are.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="10" cy="10" r="5" stroke="currentColor" stroke-width="1.5"/><circle cx="18" cy="18" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M14 14l-1.5 1.5M13.5 12.5L15 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Safety First',
    description: 'Safeguarding the health and safety of personnel, assets, and the environment is non-negotiable. It guides every decision we make.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3l9 4v8c0 6-4 9-9 10-5-1-9-4-9-10V7l9-4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M10 14l3 3 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Innovation',
    description: 'Innovation is more than a value — it\'s a strategic imperative. We drive meaningful change by collaborating with subject matter experts.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3v5M14 20v5M3 14h5M20 14h5M6 6l3 3M19 19l3 3M6 22l3-3M19 9l3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="14" cy="14" r="4" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
  {
    title: 'Genuine Care',
    description: 'We celebrate diversity and foster a team spirit that genuinely cares about our clients, our colleagues, and our communities.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 24s-10-6-10-13a6 6 0 0110-4 6 6 0 0110 4c0 7-10 13-10 13z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  },
];

const offices = [
  { city: 'Edmonton', country: 'Canada · HQ', phone: '+1 780-485-8500' },
  { city: 'Houston', country: 'United States', phone: '+1 832-390-2262' },
  { city: 'Wroclaw', country: 'Poland · Europe', phone: '+48-71-88-11-171' },
];
---

<Layout title="About Us | Metegrity" description="Global leader in asset integrity management software — 30+ years, 1,350+ facilities, $1T+ in managed assets.">
  <Navbar />
  <main>
    <PageHero
      breadcrumb={[{ label: 'Home', href: '/' }, { label: 'About Us' }]}
      eyebrow="About Metegrity"
      titleLight="Global leader in"
      titleBold="Asset Integrity Management."
      description="For over 30 years, Metegrity has powered the world's most demanding industrial operations. Today we serve 1,350+ facilities across 5 continents, managing over $1 trillion in assets."
      image="/images/photos/globe.jpg"
    >
      <div slot="cta" style="display: flex; gap: var(--space-3); flex-wrap: wrap;">
        <a href="/contact" class="btn btn-primary">Get in Touch</a>
        <a href="#history" class="btn btn-outline">Our Story</a>
      </div>
    </PageHero>

    <!-- Stats strip -->
    <section class="about-stats">
      <div class="container about-stats__inner">
        <div class="about-stats__item"><span>30+</span><label>Years of Leadership</label></div>
        <div class="about-stats__item"><span>1,350+</span><label>Facilities Worldwide</label></div>
        <div class="about-stats__item"><span>$1T+</span><label>Assets Managed</label></div>
        <div class="about-stats__item"><span>5</span><label>Continents Served</label></div>
      </div>
    </section>

    <!-- Who We Are -->
    <FeatureSplit
      eyebrow="Who We Are"
      titleLight="Innovation with"
      titleBold="operational DNA."
      description="Metegrity is a global leader in asset integrity management software. We serve asset-intensive industries — oil and gas, chemical, power, and more — with solutions built on deep operational understanding and co-innovation with our clients."
      bullets={[
        'Purpose-built AIM platform since 1992',
        '30+ years industry-specific focus',
        'Former integrity engineers in every role',
        'Co-innovation with 1,350+ clients',
      ]}
      image="/images/photos/office.jpg"
      imagePosition="right"
    />

    <!-- History / Timeline -->
    <section id="history" class="about-timeline section">
      <div class="container">
        <div class="about-timeline__header reveal">
          <div class="section-label">Our History</div>
          <h2>
            <span class="text-light">Three decades of</span><br />
            <span class="text-bold">industry leadership.</span>
          </h2>
          <p>
            From a software concept within the Lloyd's Register group to a global independent leader — Metegrity's journey mirrors the evolution of the asset integrity industry itself.
          </p>
        </div>

        <div class="about-timeline__track">
          {timeline.map((t, i) => (
            <div class="about-timeline__item reveal" style={`transition-delay: ${i * 120}ms`}>
              <div class="about-timeline__year">{t.year}</div>
              <div class="about-timeline__dot"></div>
              <div class="about-timeline__card">
                <h4>{t.title}</h4>
                <p>{t.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Vision -->
    <FeatureSplit
      eyebrow="Our Vision"
      titleLight="Empowering"
      titleBold="operational excellence."
      description="Empowering organizations to achieve maximum operational performance through innovative technologies while consistently safeguarding the health and safety of their personnel, assets, and the environment."
      bullets={[
        'Maximum operational performance',
        'Innovative, purpose-built technology',
        'Safeguarding people and environment',
        'Data-driven integrity decisions',
      ]}
      image="/images/photos/vision.jpg"
      imagePosition="left"
    />

    <!-- Values -->
    <FeatureGrid
      eyebrow="Our Values"
      titleLight="What guides us"
      titleBold="every day."
      features={values}
      columns={4}
    />

    <!-- Culture split -->
    <FeatureSplit
      eyebrow="Culture & Team"
      titleLight="Our team"
      titleBold="is our strength."
      description="A geographically distributed team united by collective spirit. We celebrate diversity, foster genuine client relationships, and build solutions together — because the best asset integrity software comes from people who understand operations from the inside."
      bullets={[
        'Distributed teams across 3 continents',
        'Diversity as a core strength',
        'Collective ownership of client success',
        'Continuous learning culture',
      ]}
      image="/images/photos/culture.jpg"
      imagePosition="right"
      ctaLabel="Join Our Team"
      ctaHref="/about/careers"
    />

    <!-- Global Offices -->
    <section class="about-offices section">
      <div class="container">
        <div class="about-offices__header reveal">
          <div class="section-label">Global Presence</div>
          <h2>
            <span class="text-light">Three offices.</span>
            <span class="text-bold">One global mission.</span>
          </h2>
        </div>

        <div class="about-offices__grid">
          {offices.map((o, i) => (
            <div class="about-office reveal" style={`transition-delay: ${i * 100}ms`}>
              <div class="about-office__pin">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M12 22s-8-6-8-13a8 8 0 0116 0c0 7-8 13-8 13z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <circle cx="12" cy="9" r="3" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </div>
              <h4>{o.city}</h4>
              <p class="about-office__country">{o.country}</p>
              <p class="about-office__phone">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M5.5 2L3 4.5C3 4.5 4 8 6 10C8 12 11.5 13 11.5 13L13 10.5L10.5 8.5L9 10C9 10 7.5 9.5 6 8C4.5 6.5 4 5 4 5L5.5 3.5L5.5 2Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
                </svg>
                {o.phone}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTASection
      titleLight="Work with"
      titleBold="the AIM leader."
      description="Whether you're evaluating integrity software, looking for consulting expertise, or exploring a career — we'd love to talk."
    />
  </main>
  <Footer />
</Layout>

<style>
  .about-stats {
    background: var(--color-dark);
    color: var(--color-white);
    padding: var(--space-12) 0;
  }

  .about-stats__inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    text-align: center;
  }

  .about-stats__item span {
    display: block;
    font-size: var(--font-size-4xl);
    font-weight: var(--font-extrabold);
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
  }

  .about-stats__item label {
    font-size: var(--font-size-xs);
    color: rgba(255,255,255,0.6);
    font-weight: var(--font-medium);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Timeline */
  .about-timeline__header {
    max-width: 700px;
    margin: 0 auto var(--space-16);
    text-align: center;
  }

  .about-timeline__header h2 {
    margin-bottom: var(--space-4);
  }

  .about-timeline__header p {
    font-size: var(--font-size-md);
    line-height: 1.7;
  }

  .about-timeline__track {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    position: relative;
  }

  .about-timeline__track::before {
    content: '';
    position: absolute;
    top: 68px;
    left: 10%;
    right: 10%;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(255, 107, 0, 0.3) 20%, rgba(255, 107, 0, 0.5) 50%, rgba(255, 107, 0, 0.3) 80%, transparent);
  }

  .about-timeline__item {
    text-align: center;
    position: relative;
  }

  .about-timeline__year {
    font-size: var(--font-size-sm);
    font-weight: var(--font-bold);
    color: var(--color-primary);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-5);
    text-transform: uppercase;
  }

  .about-timeline__dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 4px solid var(--color-bg);
    margin: 0 auto var(--space-5);
    position: relative;
    box-shadow: 0 0 0 6px rgba(255, 107, 0, 0.15);
    z-index: 1;
  }

  .about-timeline__card {
    padding: var(--space-5);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
  }

  .about-timeline__item:hover .about-timeline__card {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0,0,0,0.08);
    border-color: rgba(255, 107, 0, 0.25);
  }

  .about-timeline__card h4 {
    font-size: var(--font-size-md);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-2);
    color: var(--color-dark);
  }

  .about-timeline__card p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Offices */
  .about-offices {
    background: var(--color-bg-alt);
  }

  .about-offices__header {
    max-width: 600px;
    margin: 0 auto var(--space-16);
    text-align: center;
  }

  .about-offices__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .about-office {
    text-align: center;
    padding: var(--space-8);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: all var(--transition-base);
  }

  .about-office:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    border-color: rgba(255, 107, 0, 0.25);
  }

  .about-office__pin {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(255, 107, 0, 0.1);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-4);
  }

  .about-office h4 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-1);
  }

  .about-office__country {
    font-size: var(--font-size-sm);
    color: var(--color-primary);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-3);
  }

  .about-office__phone {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  @media (max-width: 900px) {
    .about-timeline__track { grid-template-columns: repeat(2, 1fr); gap: var(--space-8); }
    .about-timeline__track::before { display: none; }
    .about-offices__grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
  }

  @media (max-width: 768px) {
    .about-stats__inner { grid-template-columns: repeat(2, 1fr); gap: var(--space-8); }
    .about-stats__item span { font-size: var(--font-size-3xl); }
  }

  @media (max-width: 560px) {
    .about-timeline__track { grid-template-columns: 1fr; }
  }
</style>
