---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/shared/Breadcrumb.astro';
---

<Layout title="Book a Demo | Metegrity" description="See Visions Enterprise in action. Schedule a personalized 30-minute demo with our integrity experts.">
  <Navbar />
  <main>
    <section class="bad-hero">
      <img src="/images/backgrounds/hero.png" alt="" class="bad-hero__bg" aria-hidden="true" />
      <div class="bad-hero__orbs" aria-hidden="true">
        <span class="bad-hero__orb bad-hero__orb--1"></span>
        <span class="bad-hero__orb bad-hero__orb--2"></span>
      </div>
      <div class="bad-hero__overlay"></div>

      <div class="container bad-hero__inner">

        <!-- LEFT: Value proposition -->
        <div class="bad-left">
          <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Book a Demo' }]} />

          <div class="section-label" style="margin-top: var(--space-6);">Book a Demo</div>
          <h1 class="bad-left__title">
            <span class="text-light">See Metegrity</span><br />
            <span class="text-bold">in action.</span>
          </h1>
          <p class="bad-left__desc">
            A 30-minute personalized demo with our integrity experts. We'll tailor the walkthrough to your specific operational challenges — no generic slides.
          </p>

          <!-- What's included -->
          <div class="bad-includes">
            <h3>Your demo includes:</h3>
            <ul>
              <li>
                <span class="bad-includes__num">01</span>
                <div>
                  <strong>Deep-dive walkthrough</strong>
                  <p>Live tour of Visions Enterprise tailored to your asset portfolio</p>
                </div>
              </li>
              <li>
                <span class="bad-includes__num">02</span>
                <div>
                  <strong>RBI methodology discussion</strong>
                  <p>How our API 580/581 engine fits your inspection program</p>
                </div>
              </li>
              <li>
                <span class="bad-includes__num">03</span>
                <div>
                  <strong>Q&A with integrity experts</strong>
                  <p>Technical questions answered by former inspectors and engineers</p>
                </div>
              </li>
              <li>
                <span class="bad-includes__num">04</span>
                <div>
                  <strong>Tailored ROI analysis</strong>
                  <p>Scoped to your facility count and inspection volume</p>
                </div>
              </li>
            </ul>
          </div>

          <!-- Trust strip -->
          <div class="bad-trust">
            <div class="bad-trust__item">
              <span>1,350+</span>
              <label>Facilities</label>
            </div>
            <div class="bad-trust__item">
              <span>30+</span>
              <label>Years</label>
            </div>
            <div class="bad-trust__item">
              <span>$1T+</span>
              <label>Assets</label>
            </div>
          </div>

          <!-- Testimonial -->
          <blockquote class="bad-quote">
            <svg width="24" height="24" viewBox="0 0 32 24" fill="none">
              <path d="M0 24V14.4C0 6.4 4.8 1.6 14.4 0L16 3.2C11.2 4.8 8.8 7.2 8 10.4H14V24H0ZM18 24V14.4C18 6.4 22.8 1.6 32 0L33.6 3.2C28.8 4.8 26.4 7.2 25.6 10.4H32V24H18Z" fill="currentColor"/>
            </svg>
            <p>"The demo was the clearest, most relevant software presentation we've seen. They came prepared to discuss our specific challenges."</p>
            <footer>
              <div class="bad-quote__avatar">M</div>
              <div>
                <cite>Integrity Manager</cite>
                <span>Major Oil Company</span>
              </div>
            </footer>
          </blockquote>
        </div>

        <!-- RIGHT: Multi-step form -->
        <div class="bad-form">
          <div class="bad-form__card">

            <!-- Progress bar -->
            <div class="bad-form__progress">
              <div class="bad-form__progress-bar">
                <div class="bad-form__progress-fill" id="progressFill"></div>
              </div>
              <div class="bad-form__steps">
                <span class="bad-form__step bad-form__step--active" data-step="1">1</span>
                <span class="bad-form__step" data-step="2">2</span>
                <span class="bad-form__step" data-step="3">3</span>
                <span class="bad-form__step" data-step="4">4</span>
              </div>
              <div class="bad-form__step-label" id="stepLabel">Step 1 of 4 — About you</div>
            </div>

            <form id="demoForm" novalidate>

              <!-- STEP 1: About you -->
              <div class="bad-step bad-step--active" data-step="1">
                <h3>Tell us about yourself</h3>
                <p class="bad-step__desc">So we can personalize your demo.</p>

                <div class="field-row">
                  <label class="field">
                    <span class="field__label">Full Name <em>*</em></span>
                    <input type="text" name="name" placeholder="John Smith" required />
                  </label>
                  <label class="field">
                    <span class="field__label">Work Email <em>*</em></span>
                    <input type="email" name="email" placeholder="john@acme.com" required />
                  </label>
                </div>

                <div class="field-row">
                  <label class="field">
                    <span class="field__label">Company <em>*</em></span>
                    <input type="text" name="company" placeholder="Acme Energy" required />
                  </label>
                  <label class="field">
                    <span class="field__label">Country <em>*</em></span>
                    <select name="country" required>
                      <option value="">Select…</option>
                      <option>United States</option>
                      <option>Canada</option>
                      <option>United Kingdom</option>
                      <option>Saudi Arabia</option>
                      <option>UAE</option>
                      <option>Norway</option>
                      <option>Brazil</option>
                      <option>Australia</option>
                      <option>Other</option>
                    </select>
                  </label>
                </div>
              </div>

              <!-- STEP 2: Role & size -->
              <div class="bad-step" data-step="2">
                <h3>Your role &amp; organization</h3>
                <p class="bad-step__desc">Helps us match you with the right expert.</p>

                <label class="field">
                  <span class="field__label">Your Role <em>*</em></span>
                  <select name="role" required>
                    <option value="">Select…</option>
                    <option>Integrity Engineer / Inspector</option>
                    <option>Integrity Manager</option>
                    <option>Plant / Operations Manager</option>
                    <option>IT / Digital Transformation</option>
                    <option>Procurement / Buyer</option>
                    <option>Executive / C-Suite</option>
                    <option>Consultant / Advisor</option>
                  </select>
                </label>

                <label class="field">
                  <span class="field__label">Company Size <em>*</em></span>
                  <div class="radio-group">
                    <label class="radio-tile">
                      <input type="radio" name="size" value="small" required />
                      <span><strong>1 — 500</strong> employees</span>
                    </label>
                    <label class="radio-tile">
                      <input type="radio" name="size" value="mid" />
                      <span><strong>500 — 5K</strong> employees</span>
                    </label>
                    <label class="radio-tile">
                      <input type="radio" name="size" value="large" />
                      <span><strong>5K — 20K</strong> employees</span>
                    </label>
                    <label class="radio-tile">
                      <input type="radio" name="size" value="enterprise" />
                      <span><strong>20K+</strong> employees</span>
                    </label>
                  </div>
                </label>
              </div>

              <!-- STEP 3: Needs -->
              <div class="bad-step" data-step="3">
                <h3>What brings you here?</h3>
                <p class="bad-step__desc">Select all that apply. We'll focus the demo on what matters to you.</p>

                <label class="field">
                  <span class="field__label">Industry <em>*</em></span>
                  <div class="radio-group">
                    <label class="radio-tile">
                      <input type="radio" name="industry" value="og" required />
                      <span><strong>Oil & Gas</strong></span>
                    </label>
                    <label class="radio-tile">
                      <input type="radio" name="industry" value="cp" />
                      <span><strong>Chemical</strong></span>
                    </label>
                    <label class="radio-tile">
                      <input type="radio" name="industry" value="power" />
                      <span><strong>Power</strong></span>
                    </label>
                    <label class="radio-tile">
                      <input type="radio" name="industry" value="other" />
                      <span><strong>Other</strong></span>
                    </label>
                  </div>
                </label>

                <label class="field">
                  <span class="field__label">What are you exploring? <em>*</em></span>
                  <div class="check-group">
                    <label class="check-tile">
                      <input type="checkbox" name="interests" value="rbi" />
                      <span>RBI Program</span>
                    </label>
                    <label class="check-tile">
                      <input type="checkbox" name="interests" value="mi" />
                      <span>Mechanical Integrity</span>
                    </label>
                    <label class="check-tile">
                      <input type="checkbox" name="interests" value="mobile" />
                      <span>Mobile Inspections</span>
                    </label>
                    <label class="check-tile">
                      <input type="checkbox" name="interests" value="compliance" />
                      <span>PSM / Compliance</span>
                    </label>
                    <label class="check-tile">
                      <input type="checkbox" name="interests" value="corrosion" />
                      <span>Corrosion Management</span>
                    </label>
                    <label class="check-tile">
                      <input type="checkbox" name="interests" value="emissions" />
                      <span>Fugitive Emissions</span>
                    </label>
                    <label class="check-tile">
                      <input type="checkbox" name="interests" value="integration" />
                      <span>System Integration</span>
                    </label>
                    <label class="check-tile">
                      <input type="checkbox" name="interests" value="replace" />
                      <span>Replacing Legacy Tool</span>
                    </label>
                  </div>
                </label>
              </div>

              <!-- STEP 4: Schedule -->
              <div class="bad-step" data-step="4">
                <h3>When works best?</h3>
                <p class="bad-step__desc">Pick a window and we'll send a calendar invite within 1 business day.</p>

                <label class="field">
                  <span class="field__label">Timeframe <em>*</em></span>
                  <div class="radio-group">
                    <label class="radio-tile">
                      <input type="radio" name="when" value="asap" required />
                      <span><strong>This week</strong><small>ASAP</small></span>
                    </label>
                    <label class="radio-tile">
                      <input type="radio" name="when" value="next" />
                      <span><strong>Next week</strong><small>Flexible</small></span>
                    </label>
                    <label class="radio-tile">
                      <input type="radio" name="when" value="month" />
                      <span><strong>This month</strong><small>No rush</small></span>
                    </label>
                    <label class="radio-tile">
                      <input type="radio" name="when" value="exploring" />
                      <span><strong>Exploring</strong><small>Just curious</small></span>
                    </label>
                  </div>
                </label>

                <label class="field">
                  <span class="field__label">Time Zone <em>*</em></span>
                  <select name="tz" required>
                    <option value="">Select…</option>
                    <option>Americas — Mountain (MT)</option>
                    <option>Americas — Central (CT)</option>
                    <option>Americas — Eastern (ET)</option>
                    <option>Americas — Pacific (PT)</option>
                    <option>Europe — GMT/BST</option>
                    <option>Europe — CET/CEST</option>
                    <option>Middle East — GST</option>
                    <option>Asia Pacific</option>
                  </select>
                </label>

                <label class="field">
                  <span class="field__label">Anything else?</span>
                  <textarea name="notes" placeholder="Specific questions, technical context, or preferences…" rows="3"></textarea>
                </label>

                <label class="field field--check" style="margin-top: var(--space-4);">
                  <input type="checkbox" name="privacy" id="badPrivacy" required />
                  <label for="badPrivacy"><span>I agree to Metegrity's <a href="#">Privacy Policy</a> <em>*</em></span></label>
                </label>
              </div>

              <!-- SUCCESS STATE -->
              <div class="bad-step bad-success" data-step="success">
                <div class="bad-success__icon">
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                    <circle cx="24" cy="24" r="22" stroke="#FF6B00" stroke-width="2" stroke-dasharray="140" stroke-dashoffset="0"/>
                    <path d="M16 24l6 6 12-14" stroke="#FF6B00" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="40" stroke-dashoffset="0"/>
                  </svg>
                </div>
                <h3>Demo request received!</h3>
                <p>Our team will reach out within <strong>1 business day</strong> with a calendar invite. Watch your inbox — check spam folder just in case.</p>
                <div class="bad-success__next">
                  <span>While you wait:</span>
                  <a href="/insights">Explore our Insights →</a>
                  <a href="/products">Browse Products →</a>
                </div>
              </div>

              <!-- Navigation -->
              <div class="bad-form__nav">
                <button type="button" class="btn btn-outline bad-form__back" id="btnBack" style="visibility: hidden;">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <path d="M12 8H4M4 8L8 4M4 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Back
                </button>
                <button type="button" class="btn btn-primary bad-form__next" id="btnNext">
                  Continue
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <button type="submit" class="btn btn-primary bad-form__submit" id="btnSubmit" style="display: none;">
                  Request Demo
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            </form>
          </div>

          <p class="bad-form__privacy">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M6 1l6 3v3c0 3-3 4-6 4s-6-1-6-4V4l6-3z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
              <path d="M4 6l1.5 1.5L8 5" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
            </svg>
            Secure form. We never sell or share your information.
          </p>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* Hero / background */
  .bad-hero {
    position: relative;
    min-height: 100vh;
    padding: calc(var(--space-32) + var(--space-4)) 0 var(--space-20);
    overflow: hidden;
  }

  .bad-hero__bg {
    position: absolute;
    inset: -5%;
    width: 110%;
    height: 110%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
    animation: bad-drift 30s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes bad-drift {
    0%, 100% { transform: scale(1.06) translate(0, 0); }
    50% { transform: scale(1.08) translate(-1%, -0.8%); }
  }

  .bad-hero__orbs {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .bad-hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.5;
  }

  .bad-hero__orb--1 {
    width: 420px;
    height: 420px;
    top: -10%;
    left: -5%;
    background: radial-gradient(circle, rgba(255, 107, 0, 0.3), transparent 70%);
    animation: bad-orb 20s ease-in-out infinite;
  }

  .bad-hero__orb--2 {
    width: 340px;
    height: 340px;
    bottom: -10%;
    right: 5%;
    background: radial-gradient(circle, rgba(255, 138, 51, 0.22), transparent 70%);
    animation: bad-orb 24s ease-in-out infinite reverse;
  }

  @keyframes bad-orb {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(60px, 40px); }
  }

  .bad-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(248, 246, 247, 0.75) 0%, rgba(248, 246, 247, 0.55) 100%);
    z-index: 2;
    pointer-events: none;
  }

  .bad-hero__inner {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  /* Left column */
  .bad-left__title {
    font-size: var(--font-size-5xl);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: var(--space-4) 0 var(--space-5);
  }

  .bad-left__desc {
    font-size: var(--font-size-md);
    line-height: 1.7;
    margin-bottom: var(--space-8);
    max-width: 440px;
  }

  .bad-includes {
    margin-bottom: var(--space-8);
    padding: var(--space-6);
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: var(--radius-xl);
  }

  .bad-includes h3 {
    font-size: var(--font-size-sm);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .bad-includes ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .bad-includes li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .bad-includes__num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    background: var(--color-primary);
    color: var(--color-white);
    font-size: var(--font-size-xs);
    font-weight: var(--font-bold);
  }

  .bad-includes strong {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin-bottom: 2px;
  }

  .bad-includes p {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .bad-trust {
    display: flex;
    gap: var(--space-8);
    padding: var(--space-4) 0;
    margin-bottom: var(--space-6);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .bad-trust__item span {
    display: block;
    font-size: var(--font-size-xl);
    font-weight: var(--font-extrabold);
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .bad-trust__item label {
    font-size: 10px;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: var(--font-semibold);
    margin-top: 4px;
    display: block;
  }

  .bad-quote {
    padding: var(--space-5) var(--space-6);
    background: var(--color-dark);
    color: var(--color-white);
    border-radius: var(--radius-xl);
  }

  .bad-quote svg { color: var(--color-primary); margin-bottom: var(--space-3); }

  .bad-quote p {
    font-size: var(--font-size-sm);
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    font-style: italic;
  }

  .bad-quote footer {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .bad-quote__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: var(--font-bold);
    font-size: var(--font-size-xs);
  }

  .bad-quote cite {
    display: block;
    font-style: normal;
    font-size: var(--font-size-xs);
    font-weight: var(--font-bold);
    color: var(--color-white);
  }

  .bad-quote footer span {
    font-size: 10px;
    color: rgba(255,255,255,0.5);
  }

  /* Right form */
  .bad-form {
    position: sticky;
    top: 100px;
  }

  .bad-form__card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
  }

  /* Progress */
  .bad-form__progress {
    margin-bottom: var(--space-8);
  }

  .bad-form__progress-bar {
    height: 4px;
    background: var(--color-bg-alt);
    border-radius: var(--radius-pill);
    overflow: hidden;
    margin-bottom: var(--space-4);
  }

  .bad-form__progress-fill {
    height: 100%;
    width: 25%;
    background: linear-gradient(90deg, var(--color-primary), #FF8A33);
    border-radius: var(--radius-pill);
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .bad-form__steps {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--space-3);
  }

  .bad-form__step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    font-weight: var(--font-bold);
    border: 2px solid transparent;
    transition: all var(--transition-base);
  }

  .bad-form__step--active {
    background: var(--color-primary);
    color: var(--color-white);
    border-color: rgba(255, 107, 0, 0.2);
    box-shadow: 0 0 0 4px rgba(255, 107, 0, 0.1);
  }

  .bad-form__step--done {
    background: rgba(255, 107, 0, 0.15);
    color: var(--color-primary);
  }

  .bad-form__step-label {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: var(--font-semibold);
  }

  /* Steps */
  .bad-step {
    display: none;
    flex-direction: column;
    gap: var(--space-4);
    animation: step-in 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .bad-step--active { display: flex; }

  @keyframes step-in {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .bad-step h3 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    letter-spacing: -0.01em;
  }

  .bad-step__desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-top: calc(-1 * var(--space-3));
  }

  /* Fields */
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .field__label {
    font-size: var(--font-size-xs);
    font-weight: var(--font-semibold);
    color: var(--color-dark);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .field__label em {
    font-style: normal;
    color: var(--color-primary);
    margin-left: 2px;
  }

  .field input,
  .field select,
  .field textarea {
    padding: var(--space-3) var(--space-4);
    font-size: var(--font-size-sm);
    font-family: inherit;
    color: var(--color-dark);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background: var(--color-white);
    box-shadow: 0 0 0 3px rgba(255,107,0,0.12);
  }

  .field textarea {
    resize: vertical;
    min-height: 80px;
  }

  /* Radio tiles */
  .radio-group {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  .radio-tile {
    position: relative;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .radio-tile input { position: absolute; opacity: 0; pointer-events: none; }

  .radio-tile span {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: var(--font-size-sm);
    color: var(--color-dark);
  }

  .radio-tile strong {
    font-size: var(--font-size-sm);
    font-weight: var(--font-bold);
  }

  .radio-tile small {
    font-size: 11px;
    color: var(--color-text-secondary);
    font-weight: var(--font-medium);
  }

  .radio-tile:hover {
    border-color: rgba(255, 107, 0, 0.4);
  }

  .radio-tile:has(input:checked) {
    border-color: var(--color-primary);
    background: rgba(255, 107, 0, 0.05);
  }

  /* Check tiles */
  .check-group {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  .check-tile {
    position: relative;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: var(--font-size-sm);
    font-weight: var(--font-medium);
    color: var(--color-dark);
    transition: all var(--transition-fast);
  }

  .check-tile input { position: absolute; opacity: 0; pointer-events: none; }

  .check-tile span {
    position: relative;
    padding-left: var(--space-6);
  }

  .check-tile span::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    border: 1.5px solid var(--color-border);
    border-radius: 3px;
    background: var(--color-white);
    transition: all var(--transition-fast);
  }

  .check-tile:has(input:checked) {
    border-color: var(--color-primary);
    background: rgba(255, 107, 0, 0.05);
    color: var(--color-primary);
  }

  .check-tile:has(input:checked) span::before {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .check-tile:has(input:checked) span::after {
    content: '';
    position: absolute;
    left: 4px;
    top: 50%;
    width: 8px;
    height: 5px;
    transform: translateY(-70%) rotate(-45deg);
    border-left: 2px solid var(--color-white);
    border-bottom: 2px solid var(--color-white);
  }

  /* Privacy checkbox */
  .field--check {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .field--check input[type="checkbox"] {
    width: 18px;
    height: 18px;
    padding: 0;
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--color-primary);
  }

  .field--check span,
  .field--check label {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
    cursor: pointer;
  }

  .field--check a { color: var(--color-primary); font-weight: var(--font-semibold); }
  .field--check em { color: var(--color-primary); font-style: normal; }

  /* Navigation */
  .bad-form__nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .bad-form__privacy {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-4);
    justify-content: center;
    width: 100%;
  }

  /* Success */
  .bad-success { text-align: center; align-items: center; padding: var(--space-6) 0; }

  .bad-success__icon {
    width: 80px;
    height: 80px;
    margin: 0 auto var(--space-4);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 107, 0, 0.1);
    border-radius: 50%;
  }

  .bad-success h3 {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-3);
  }

  .bad-success p {
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 400px;
    margin: 0 auto var(--space-6);
  }

  .bad-success__next {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .bad-success__next span {
    font-size: var(--font-size-xs);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-2);
  }

  .bad-success__next a {
    font-size: var(--font-size-sm);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .bad-hero__inner { grid-template-columns: 1fr; }
    .bad-form { position: static; }
    .bad-left__title { font-size: var(--font-size-4xl); }
  }

  @media (max-width: 768px) {
    .field-row { grid-template-columns: 1fr; }
    .radio-group,
    .check-group { grid-template-columns: 1fr; }
    .bad-form__card { padding: var(--space-6); }
    .bad-trust { gap: var(--space-5); }
    .bad-trust__item span { font-size: var(--font-size-lg); }
  }
</style>

<script>
  const form = document.getElementById('demoForm') as HTMLFormElement | null;
  const steps = document.querySelectorAll<HTMLElement>('.bad-step:not(.bad-success)');
  const stepIndicators = document.querySelectorAll<HTMLElement>('.bad-form__step');
  const progressFill = document.getElementById('progressFill') as HTMLElement | null;
  const stepLabel = document.getElementById('stepLabel');
  const btnBack = document.getElementById('btnBack') as HTMLButtonElement | null;
  const btnNext = document.getElementById('btnNext') as HTMLButtonElement | null;
  const btnSubmit = document.getElementById('btnSubmit') as HTMLButtonElement | null;

  const totalSteps = 4;
  const stepTitles: Record<number, string> = {
    1: 'Step 1 of 4 — About you',
    2: 'Step 2 of 4 — Role & organization',
    3: 'Step 3 of 4 — Your needs',
    4: 'Step 4 of 4 — Schedule',
  };

  let current = 1;

  function validateStep(step: number): boolean {
    if (!form) return false;
    const stepEl = form.querySelector<HTMLElement>(`.bad-step[data-step="${step}"]`);
    if (!stepEl) return false;
    const required = stepEl.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('input[required], select[required], textarea[required]');
    for (const el of required) {
      if (el.type === 'radio') {
        const name = el.name;
        const checked = form.querySelector(`input[name="${name}"]:checked`);
        if (!checked) { (el as HTMLElement).focus(); form.reportValidity(); return false; }
      } else if (!el.value || !el.checkValidity()) {
        el.focus();
        form.reportValidity();
        return false;
      }
    }
    return true;
  }

  function setStep(n: number) {
    steps.forEach(s => s.classList.remove('bad-step--active'));
    const target = form?.querySelector<HTMLElement>(`.bad-step[data-step="${n}"]`);
    target?.classList.add('bad-step--active');
    current = n;

    stepIndicators.forEach((el, i) => {
      const num = i + 1;
      el.classList.remove('bad-form__step--active', 'bad-form__step--done');
      if (num < n) el.classList.add('bad-form__step--done');
      else if (num === n) el.classList.add('bad-form__step--active');
    });

    if (progressFill) progressFill.style.width = `${(n / totalSteps) * 100}%`;
    if (stepLabel) stepLabel.textContent = stepTitles[n] || '';
    if (btnBack) btnBack.style.visibility = n === 1 ? 'hidden' : 'visible';
    if (btnNext) btnNext.style.display = n === totalSteps ? 'none' : 'inline-flex';
    if (btnSubmit) btnSubmit.style.display = n === totalSteps ? 'inline-flex' : 'none';
  }

  btnNext?.addEventListener('click', () => {
    if (!validateStep(current)) return;
    if (current < totalSteps) setStep(current + 1);
  });

  btnBack?.addEventListener('click', () => {
    if (current > 1) setStep(current - 1);
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!validateStep(current)) return;
    if (!form.checkValidity()) { form.reportValidity(); return; }

    // Show success
    steps.forEach(s => s.classList.remove('bad-step--active'));
    form.querySelector('.bad-success')?.classList.add('bad-step--active');

    // Hide nav
    const nav = form.querySelector<HTMLElement>('.bad-form__nav');
    if (nav) nav.style.display = 'none';

    // Update progress to complete
    if (progressFill) progressFill.style.width = '100%';
    stepIndicators.forEach(el => el.classList.add('bad-form__step--done'));
    if (stepLabel) stepLabel.textContent = '✓ Completed';
  });
</script>
