---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import LegalLayout from '../../components/shared/LegalLayout.astro';

const sections = [
  { id: 'acceptance', title: 'Acceptance of Terms' },
  { id: 'services', title: 'Our Services' },
  { id: 'accounts', title: 'Accounts & Registration' },
  { id: 'license', title: 'License Grant' },
  { id: 'restrictions', title: 'Use Restrictions' },
  { id: 'content', title: 'Customer Content' },
  { id: 'payment', title: 'Fees & Payment' },
  { id: 'confidentiality', title: 'Confidentiality' },
  { id: 'warranties', title: 'Warranties & Disclaimers' },
  { id: 'liability', title: 'Limitation of Liability' },
  { id: 'indemnification', title: 'Indemnification' },
  { id: 'termination', title: 'Termination' },
  { id: 'governing', title: 'Governing Law' },
  { id: 'general', title: 'General Provisions' },
];
---

<Layout title="Terms & Conditions | Metegrity" description="The legal terms governing your use of Metegrity products, services, and website.">
  <Navbar />
  <main>
