---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import LegalLayout from '../../components/shared/LegalLayout.astro';

const sections = [
  { id: 'what', title: 'What Are Cookies' },
  { id: 'why', title: 'How We Use Cookies' },
  { id: 'types', title: 'Types of Cookies' },
  { id: 'third-party', title: 'Third-Party Cookies' },
  { id: 'manage', title: 'Managing Cookies' },
  { id: 'changes', title: 'Changes' },
  { id: 'contact', title: 'Contact Us' },
];
---

<Layout title="Cookie Policy | Metegrity" description="How Metegrity uses cookies and similar tracking technologies on our website.">
  <Navbar />
  <main>
    <LegalLayout
      title="Cookie Policy"
      subtitle="This policy explains how Metegrity uses cookies and similar tracking technologies to enhance your experience and analyze website traffic."
      lastUpdated="December 15, 2026"
      version="2.0"
      sections={sections}
    >

      <section id="what">
        <h2><span class="legal-num">01</span>What Are Cookies</h2>
        <p>Cookies are small text files that are placed on your computer, smartphone, or other device when you visit a website. They are widely used to make websites work more efficiently, provide a better user experience, and supply information to site owners.</p>
        <p>Cookies can be "<strong>persistent</strong>" or "<strong>session</strong>" cookies. Persistent cookies remain on your device after you close your browser and are activated each time you revisit the website that created them. Session cookies are temporary and are deleted when you close your browser.</p>
        <p>In addition to cookies, we may use similar technologies such as web beacons (pixel tags), local storage, and device fingerprinting to collect and store information about your interactions with our Services.</p>
      </section>

      <section id="why">
        <h2><span class="legal-num">02</span>How We Use Cookies</h2>
        <p>Metegrity uses cookies and similar technologies for the following purposes:</p>
        <ol>
          <li><strong>Authentication and Security</strong> — To verify your identity, maintain your session, and protect against unauthorized access to your account.</li>
          <li><strong>Preferences and Settings</strong> — To remember your choices, such as language preferences, display settings, and region selection, so you do not have to re-enter them each time you visit.</li>
          <li><strong>Performance and Analytics</strong> — To collect aggregated, anonymized data about how visitors use our website, including which pages are most frequently visited, how long visitors spend on each page, and where visitors encounter errors.</li>
          <li><strong>Functionality</strong> — To enable enhanced features and personalization, such as remembering your recent activity, pre-filling forms, and providing relevant content recommendations.</li>
          <li><strong>Marketing and Advertising</strong> — To deliver relevant advertisements, measure the effectiveness of our marketing campaigns, and limit the number of times you see a particular advertisement.</li>
        </ol>
      </section>

      <section id="types">
        <h2><span class="legal-num">03</span>Types of Cookies</h2>
        <p>The following table describes the categories of cookies we use on our website:</p>

        <table>
          <thead>
            <tr>
              <th>Category</th>
              <th>Description</th>
              <th>Examples</th>
              <th>Duration</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Strictly Necessary</strong></td>
              <td>Essential for the website to function. These cookies enable core functionality such as security, authentication, and session management. The website cannot function properly without them.</td>
              <td>Session ID, CSRF token, authentication cookies</td>
              <td>Session to 1 year</td>
            </tr>
            <tr>
              <td><strong>Performance</strong></td>
              <td>Collect anonymous information about how visitors use our website, including which pages are visited most often and whether users encounter error messages. All data is aggregated and anonymous.</td>
              <td>Google Analytics (_ga, _gid), page load timing</td>
              <td>Up to 2 years</td>
            </tr>
            <tr>
              <td><strong>Functionality</strong></td>
              <td>Allow the website to remember choices you make and provide enhanced, personalized features. They may be set by us or by third-party providers whose services we have added to our pages.</td>
              <td>Language preference, region selection, display settings</td>
              <td>Up to 1 year</td>
            </tr>
            <tr>
              <td><strong>Marketing</strong></td>
              <td>Used to track visitors across websites and display relevant advertisements. These cookies are used to deliver ads that are relevant to your interests and to measure the effectiveness of advertising campaigns.</td>
              <td>LinkedIn Insight Tag, HubSpot tracking code, retargeting pixels</td>
              <td>Up to 2 years</td>
            </tr>
          </tbody>
        </table>

        <div class="legal-callout">
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 5v3M8 10.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <p><strong>Strictly Necessary Cookies</strong>These cookies cannot be disabled as they are essential for the website to function. They do not store any personally identifiable information.</p>
        </div>
      </section>

      <section id="third-party">
        <h2><span class="legal-num">04</span>Third-Party Cookies</h2>
        <p>Some cookies on our website are placed by third-party services that we use to enhance functionality, analyze usage, and deliver targeted content. These third parties include:</p>
        <ul>
          <li><strong>Google Analytics</strong> — We use Google Analytics to understand how visitors interact with our website. Google Analytics uses cookies to collect anonymized usage data, including pages visited, session duration, and traffic sources. You can opt out of Google Analytics by installing the <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener noreferrer">Google Analytics Opt-out Browser Add-on</a>.</li>
          <li><strong>LinkedIn</strong> — We use the LinkedIn Insight Tag to track conversions from LinkedIn advertising campaigns and to enable retargeting of website visitors on LinkedIn. You can manage your LinkedIn advertising preferences in your <a href="https://www.linkedin.com/psettings/advertising" target="_blank" rel="noopener noreferrer">LinkedIn Settings</a>.</li>
          <li><strong>HubSpot</strong> — We use HubSpot for marketing automation, lead tracking, and analytics. HubSpot cookies help us understand how visitors engage with our content and enable us to personalize communications. You can learn more about HubSpot's cookie practices in their <a href="https://legal.hubspot.com/privacy-policy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>.</li>
        </ul>
        <p>These third parties may use the information collected through cookies for their own purposes, subject to their respective privacy policies. We encourage you to review the privacy policies of these third parties.</p>
      </section>

      <section id="manage">
        <h2><span class="legal-num">05</span>Managing Cookies</h2>
        <p>You have several options for managing and controlling cookies:</p>

        <h3>Browser Settings</h3>
        <p>Most web browsers allow you to manage cookies through their settings. You can typically configure your browser to block all cookies, accept all cookies, or notify you when a cookie is set. The methods for managing cookies vary by browser. Consult your browser's help documentation for instructions:</p>
        <ul>
          <li><a href="https://support.google.com/chrome/answer/95647" target="_blank" rel="noopener noreferrer">Google Chrome</a></li>
          <li><a href="https://support.mozilla.org/en-US/kb/cookies-information-websites-store-on-your-computer" target="_blank" rel="noopener noreferrer">Mozilla Firefox</a></li>
          <li><a href="https://support.apple.com/guide/safari/manage-cookies-sfri11471" target="_blank" rel="noopener noreferrer">Apple Safari</a></li>
          <li><a href="https://support.microsoft.com/en-us/microsoft-edge/delete-cookies-in-microsoft-edge-63947406-40ac-c3b8-57b9-2a946a29ae09" target="_blank" rel="noopener noreferrer">Microsoft Edge</a></li>
        </ul>

        <h3>Opt-Out Links</h3>
        <p>You can also opt out of certain third-party cookies using the following industry tools:</p>
        <ul>
          <li><a href="https://optout.networkadvertising.org/" target="_blank" rel="noopener noreferrer">Network Advertising Initiative (NAI) Opt-Out</a></li>
          <li><a href="https://optout.aboutads.info/" target="_blank" rel="noopener noreferrer">Digital Advertising Alliance (DAA) Opt-Out</a></li>
          <li><a href="https://youronlinechoices.eu/" target="_blank" rel="noopener noreferrer">European Interactive Digital Advertising Alliance (EDAA)</a></li>
        </ul>

        <h3>Do Not Track</h3>
        <p>Some browsers offer a "Do Not Track" (DNT) feature that sends a signal to websites requesting that your browsing activity not be tracked. At this time, there is no universally accepted standard for how websites should respond to DNT signals. Our website does not currently respond to DNT signals, but we continue to monitor developments in this area.</p>

        <div class="legal-callout">
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 5v3M8 10.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <p><strong>Please Note</strong>Disabling or blocking certain cookies may affect the functionality of our website. Some features may not work as intended if cookies are disabled.</p>
        </div>
      </section>

      <section id="changes">
        <h2><span class="legal-num">06</span>Changes</h2>
        <p>We may update this Cookie Policy from time to time to reflect changes in the cookies we use, changes in technology, or changes in applicable laws and regulations. When we make material changes, we will:</p>
        <ul>
          <li>Post the updated Cookie Policy on our website with a revised "Last Updated" date</li>
          <li>Update the cookie consent banner to reflect any new categories or uses of cookies</li>
          <li>Provide reasonable notice to users where required by applicable law</li>
        </ul>
        <p>We encourage you to review this Cookie Policy periodically to stay informed about how we use cookies. Your continued use of our website after any changes constitutes your acceptance of the updated Cookie Policy.</p>
      </section>

      <section id="contact">
        <h2><span class="legal-num">07</span>Contact Us</h2>
        <p>If you have any questions or concerns about our use of cookies or this Cookie Policy, please contact us:</p>
        <ul>
          <li><strong>Email:</strong> <a href="mailto:privacy@metegrity.com">privacy@metegrity.com</a></li>
          <li><strong>Data Protection Officer:</strong> <a href="mailto:dpo@metegrity.com">dpo@metegrity.com</a></li>
        </ul>
        <p><strong>Metegrity Inc.</strong><br/>
        5715-76 Avenue<br/>
        Edmonton, AB T6B 0A7<br/>
        Canada</p>
      </section>

    </LegalLayout>
  </main>
  <Footer />
</Layout>
