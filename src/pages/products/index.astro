---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/shared/PageHero.astro';
import CTASection from '../../components/shared/CTASection.astro';

const products = [
  {
    name: 'Visions Enterprise',
    tagline: 'Core Platform',
    description: 'The foundation for intelligent asset integrity. Industry-leading AIM solution on a single platform, from wellhead to shipping terminal.',
    features: ['Single unified platform', 'SAP / EAM / CMMS integration', 'Single to multi-site deployment'],
    href: '/products/visions-enterprise',
    image: '/images/photos/refinery.jpg',
  },
  {
    name: 'VISIONSGO',
    tagline: 'Mobile Solution',
    description: 'Field insights — anywhere, anytime. Execute inspection management with our mobile data management solution with real-time syncing.',
    features: ['Real-time data capture', 'Offline-first design', 'Seamless syncing'],
    href: '/products/visionsgo',
    image: '/images/photos/engineer-field.jpg',
  },
  {
    name: 'Visions RBI Bundle',
    tagline: 'Risk Analytics',
    description: 'Risk-based decisions, smarter inspections. API RP 580/581 compliant with qualitative, semi-quantitative and fully quantitative risk models.',
    features: ['API 580/581 compliant', 'Multiple risk models', 'Probability vs. Consequence'],
    href: '/products/visions-rbi',
    image: '/images/photos/control-room.jpg',
  },
  {
    name: 'Fugitive Emissions',
    tagline: 'Compliance',
    description: 'Advanced leak detection and repair management. Maintenance integration, regulatory compliance, and real-time emissions monitoring.',
    features: ['LDAR workflows', 'Real-time monitoring', 'Compliance reporting'],
    href: '/products/fugitive-emissions',
    image: '/images/photos/pipeline.jpg',
  },
];
---

<Layout title="Products | Metegrity" description="Reliable Solutions for Asset Integrity — High value products for high value equipment.">
  <Navbar />
  <main>
    <PageHero
      breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Products' }]}
      eyebrow="Products"
      titleLight="Reliable Solutions for"
      titleBold="Asset Integrity."
      description="High value products for high value equipment. From field inspections to enterprise-wide risk management — our product suite powers asset integrity across the lifecycle."
      align="center"
    />

    <section class="prod-list section">
      <div class="container">
        {products.map((p, i) => (
          <article class={`prod-list__item reveal ${i % 2 === 1 ? 'prod-list__item--reverse' : ''}`} style={`transition-delay: ${i * 80}ms`}>
            <div class="prod-list__visual">
              <img src={p.image} alt={p.name} loading="lazy" />
              <span class="prod-list__tag badge badge-primary">{p.tagline}</span>
            </div>
            <div class="prod-list__content">
              <h2 class="prod-list__name">{p.name}</h2>
              <p class="prod-list__desc">{p.description}</p>
              <ul class="prod-list__features">
                {p.features.map(f => (
                  <li>
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <circle cx="8" cy="8" r="7" stroke="#FF6B00" stroke-width="1.5"/>
                      <path d="M5 8L7 10L11 6" stroke="#FF6B00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a href={p.href} class="btn btn-dark">
                Explore {p.name}
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                  <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <CTASection />
  </main>
  <Footer />
</Layout>

<style>
  .prod-list__item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
    padding: var(--space-16) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .prod-list__item:last-child { border-bottom: none; }

  .prod-list__item--reverse {
    direction: rtl;
  }

  .prod-list__item--reverse .prod-list__content,
  .prod-list__item--reverse .prod-list__visual {
    direction: ltr;
  }

  .prod-list__visual {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.12);
  }

  .prod-list__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 6s ease;
  }

  .prod-list__item:hover .prod-list__visual img {
    transform: scale(1.04);
  }

  .prod-list__tag {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .prod-list__name {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  .prod-list__desc {
    font-size: var(--font-size-md);
    line-height: 1.7;
    margin-bottom: var(--space-5);
    max-width: 480px;
  }

  .prod-list__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .prod-list__features li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--color-dark);
    font-weight: var(--font-medium);
  }

  @media (max-width: 900px) {
    .prod-list__item,
    .prod-list__item--reverse {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      direction: ltr;
      text-align: center;
    }
    .prod-list__desc { margin-left: auto; margin-right: auto; }
    .prod-list__features li { justify-content: center; }
    .prod-list__name { font-size: var(--font-size-2xl); }
  }
</style>
