---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/shared/PageHero.astro';
import FeatureGrid from '../../components/shared/FeatureGrid.astro';
import FeatureSplit from '../../components/shared/FeatureSplit.astro';
import CTASection from '../../components/shared/CTASection.astro';

const methodologies = [
  {
    title: 'Qualitative RBI',
    description: 'Rapid screening with expert judgment. Ideal for initial risk ranking and less critical assets.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="4" width="20" height="20" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M9 14l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Semi-Quantitative',
    description: 'Balanced approach combining expert input with calculated damage factors. The industry sweet-spot.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 24h20M6 20V10M11 20V6M16 20v-8M21 20v-14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Fully Quantitative',
    description: 'Deep numerical analysis using probability distributions and Monte Carlo simulations.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 20L10 12L15 16L24 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="10" cy="12" r="2" fill="currentColor"/><circle cx="15" cy="16" r="2" fill="currentColor"/><circle cx="24" cy="6" r="2" fill="currentColor"/></svg>`,
  },
];

const benefits = [
  {
    title: 'Optimized Inspection Intervals',
    description: 'Extend intervals for low-risk assets. Focus resources on what actually threatens reliability.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="11" stroke="currentColor" stroke-width="1.5"/><path d="M14 6V14L20 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Damage Mechanism Library',
    description: 'Pre-built database of 60+ damage mechanisms. Correlate with operating conditions automatically.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M6 22V10l8-6 8 6v12z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M10 14h8M10 18h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Risk Matrix Visualization',
    description: 'Interactive 5x5 or 6x6 matrices with drill-down to individual assets and mechanisms.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="4" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="4" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="18" y="4" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="4" y="11" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="11" width="6" height="6" fill="currentColor" opacity="0.3" stroke="currentColor" stroke-width="1.5"/><rect x="18" y="11" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="4" y="18" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="18" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="18" y="18" width="6" height="6" fill="currentColor" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
  {
    title: 'Cost-Benefit Analysis',
    description: 'Quantify the ROI of each inspection. Justify capital spend with hard numbers.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="11" stroke="currentColor" stroke-width="1.5"/><path d="M11 10h4a2.5 2.5 0 010 5h-4a2.5 2.5 0 000 5h4M14 7v3M14 20v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
];
---

<Layout title="Visions RBI Bundle | Metegrity" description="Risk-based decisions, smarter inspections. API RP 580/581 compliant risk models.">
  <Navbar />
  <main>
    <PageHero
      eyebrow="Visions RBI Bundle"
      titleLight="Risk-Based Decisions."
      titleBold="Smarter Inspections."
      description="Intelligently analyze equipment's probability of failure vs. consequence of failure. API RP 580/581 compliant with three risk model methodologies — choose the rigor that fits your assets."
      image="/images/photos/control-room.jpg"
    >
      <div slot="cta" style="display: flex; gap: var(--space-3); flex-wrap: wrap;">
        <a href="/contact" class="btn btn-primary">Book a Demo</a>
        <a href="#methodologies" class="btn btn-outline">See Methodologies</a>
      </div>
    </PageHero>

    <!-- Compliance bar -->
    <section class="rbi-compliance">
      <div class="container">
        <div class="rbi-compliance__inner">
          <span class="rbi-compliance__label">Compliant with</span>
          <div class="rbi-compliance__badges">
            <span>API RP 580</span>
            <span>API RP 581</span>
            <span>ASME PCC-3</span>
            <span>ISO 31000</span>
          </div>
        </div>
      </div>
    </section>

    <section id="methodologies">
      <FeatureGrid
        eyebrow="Methodologies"
        titleLight="Three approaches."
        titleBold="One powerful platform."
        description="Choose the rigor that matches your asset criticality. Qualitative for quick screening, quantitative for high-stakes decisions."
        features={methodologies}
        columns={3}
      />
    </section>

    <FeatureSplit
      eyebrow="Intelligent Risk Scoring"
      titleLight="Probability × Consequence ="
      titleBold="Clarity."
      description="Our RBI engine evaluates each asset against 60+ damage mechanisms, calculating probability of failure from thickness trends, operating conditions, and damage history. Combined with consequence modeling, you get a defensible risk ranking."
      bullets={[
        'Automated damage factor calculations',
        'Consequence analysis (safety, environmental, financial)',
        '5×5 and 6×6 risk matrix support',
        'What-if scenario modeling',
      ]}
      image="/images/photos/data-analysis.jpg"
      imagePosition="right"
    />

    <FeatureGrid
      eyebrow="What You Get"
      titleLight="Beyond compliance."
      titleBold="Real business impact."
      features={benefits}
      columns={2}
      dark={true}
    />

    <FeatureSplit
      eyebrow="Proven in the Field"
      titleLight="From RBI study to"
      titleBold="inspection execution."
      description="Visions RBI integrates natively with Visions Enterprise. RBI recommendations flow directly into inspection planning, work orders, and execution tracking — closing the loop from analysis to action."
      bullets={[
        'Seamless handoff to inspection workflow',
        'Dynamic re-evaluation after each inspection',
        'Optimized inspection intervals per asset',
        'Full audit trail for regulators',
      ]}
      image="/images/photos/refinery.jpg"
      imagePosition="left"
    />

    <CTASection
      titleLight="Turn risk data"
      titleBold="into smarter decisions."
      description="Discover how leading operators use Visions RBI to optimize inspection programs and reduce unplanned downtime."
    />
  </main>
  <Footer />
</Layout>

<style>
  .rbi-compliance {
    background: var(--color-dark);
    color: var(--color-white);
    padding: var(--space-8) 0;
  }

  .rbi-compliance__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .rbi-compliance__label {
    font-size: var(--font-size-xs);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.5);
  }

  .rbi-compliance__badges {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  .rbi-compliance__badges span {
    padding: var(--space-2) var(--space-4);
    background: rgba(255, 107, 0, 0.12);
    color: var(--color-primary);
    border: 1px solid rgba(255, 107, 0, 0.25);
    border-radius: var(--radius-pill);
    font-size: var(--font-size-sm);
    font-weight: var(--font-semibold);
  }
</style>
