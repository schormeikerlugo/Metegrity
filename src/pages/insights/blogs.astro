---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/shared/PageHero.astro';
import ResourceCard from '../../components/shared/ResourceCard.astro';
import CTASection from '../../components/shared/CTASection.astro';
import FilterBar from '../../components/shared/FilterBar.astro';

const featured = {
  type: 'Featured Article',
  title: 'Thickness Measurements: From Probe to Risk-Based Assessment',
  description: 'Explore the full lifecycle of thickness measurement data — from initial probe readings in the field to comprehensive risk-based assessments that drive smarter inspection planning and extend equipment life.',
  image: '/images/photos/blog-thickness.jpg',
  meta: 'Mar 18, 2026 · 6 min read',
  tag: 'Editor\'s Pick',
  href: '/insights/blogs/thickness-measurements',
  featured: true,
};

const categories = ['All', 'RBI', 'Corrosion', 'Pipeline', 'Compliance', 'Integration', 'PSM'];

const posts = [
  { type: 'Article', title: 'The Hidden Circuit Risk: When Digital and Physical Diverge', image: '/images/photos/blog-circuit.jpg', meta: 'Feb 2026 · 5 min', tag: 'Corrosion', href: '/insights/blogs/hidden-circuit-risk' },
  { type: 'Article', title: '5 Ways to Improve Regulatory Compliance in Biofuels', image: '/images/photos/blog-biofuels.jpg', meta: 'Aug 2024 · 5 min', tag: 'Compliance', href: '/insights/blogs/biofuels-compliance' },
  { type: 'Article', title: 'Improve Midstream ROI: One Pipeline Integrity Software', image: '/images/photos/blog-pipeline.jpg', meta: 'Mar 2024 · 6 min', tag: 'Pipeline', href: '/insights/blogs/midstream-roi' },
  { type: 'Article', title: 'The Necessity of AIM for the Petrochemical Sector', image: '/images/photos/blog-petrochemical.jpg', meta: 'Mar 2024 · 5 min', tag: 'Compliance', href: '/insights/blogs/petrochemical-aim' },
  { type: 'Article', title: 'Integrity Operating Windows Reduce Inspection Frequency', image: '/images/photos/blog-iow.jpg', meta: 'Mar 2024 · 4 min', tag: 'RBI', href: '/insights/blogs/iow-inspection' },
  { type: 'Article', title: 'Implementation of a Risk Based Inspection Program', image: '/images/photos/blog-rbi.jpg', meta: 'Mar 2024 · 7 min', tag: 'RBI', href: '/insights/blogs/rbi-implementation' },
  { type: 'Article', title: 'Risk Based Inspection — Why Consider it?', image: '/images/photos/blog-risk.jpg', meta: 'Mar 2024 · 5 min', tag: 'RBI', href: '/insights/blogs/rbi-why' },
  { type: 'Article', title: 'AIM Technology That Solves Real Business Problems', image: '/images/photos/blog-data.jpg', meta: 'Mar 2024 · 6 min', tag: 'Integration', href: '/insights/blogs/aim-technology' },
  { type: 'Article', title: 'Integrating Your Inspection Software and CMMS', image: '/images/photos/blog-cmms.jpg', meta: 'Oct 2023 · 5 min', tag: 'Integration', href: '/insights/blogs/cmms-integration' },
  { type: 'Article', title: 'Coupling AIM with Process Safety Management', image: '/images/photos/blog-psm.jpg', meta: 'Oct 2023 · 6 min', tag: 'PSM', href: '/insights/blogs/aim-psm' },
  { type: 'Article', title: 'Improving Asset Performance: Reliability Engineering Techniques', image: '/images/photos/blog-reliability.jpg', meta: 'Oct 2023 · 7 min', tag: 'Integration', href: '/insights/blogs/reliability-engineering' },
  { type: 'Article', title: 'The Role of Advanced Data Management in AIM', image: '/images/photos/blog-integration.jpg', meta: 'Oct 2023 · 5 min', tag: 'Integration', href: '/insights/blogs/data-management' },
];
---

<Layout title="Blog | Metegrity" description="Expert commentary on asset integrity management trends, best practices, and industry analysis.">
  <Navbar />
  <main>
    <PageHero
      eyebrow="Blog"
      titleLight="Expert commentary"
      titleBold="on AIM trends."
      description="Weekly articles from Metegrity engineers, consultants, and industry veterans. Practical insights you can apply to your integrity programs today."
      align="center"
    />

    <!-- Featured -->
    <section class="blog-featured section">
      <div class="container">
        <ResourceCard {...featured} />
      </div>
    </section>

    <!-- Posts grid with filter -->
    <section class="blog-grid section">
      <div class="container">
        <div class="blog-grid__header reveal">
          <div class="section-label">Recent Articles</div>
          <h2>
            <span class="text-light">Fresh thinking</span>
            <span class="text-bold">every week.</span>
          </h2>
        </div>

        <FilterBar categories={categories} targetGrid=".blog-grid__list" />

        <div class="blog-grid__list">
          {posts.map((p) => (
            <div class="blog-grid__item" data-tag={p.tag}>
              <ResourceCard {...p} />
            </div>
          ))}
        </div>

        <div class="blog-grid__pagination reveal">
          <button class="blog-page blog-page--prev" disabled aria-label="Previous page">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M12 8H4M4 8L8 4M4 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="blog-page blog-page--active">1</button>
          <button class="blog-page">2</button>
          <button class="blog-page">3</button>
          <span class="blog-page blog-page--dots">…</span>
          <button class="blog-page">12</button>
          <button class="blog-page blog-page--next" aria-label="Next page">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    </section>

    <CTASection
      titleLight="Get blog updates"
      titleBold="in your inbox."
      description="Weekly digest of the best articles — curated by our editorial team. Unsubscribe anytime."
      primaryLabel="Subscribe"
    />
  </main>
  <Footer />
</Layout>

<style>
  .blog-featured :global(.rcard--featured) { max-width: 100%; }

  .blog-grid__header {
    max-width: 640px;
    margin-bottom: var(--space-10);
  }

  .blog-grid__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    margin-bottom: var(--space-12);
  }

  /* Pagination */
  .blog-grid__pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
  }

  .blog-page {
    min-width: 38px;
    height: 38px;
    padding: 0 var(--space-2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: var(--font-size-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text-secondary);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
    font-family: inherit;
  }

  .blog-page:hover:not(:disabled):not(.blog-page--dots) {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .blog-page--active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-white) !important;
  }

  .blog-page:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .blog-page--dots {
    border: none;
    cursor: default;
  }

  @media (max-width: 900px) {
    .blog-grid__list { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .blog-grid__list { grid-template-columns: 1fr; }
    .blog-grid__header { text-align: center; margin-left: auto; margin-right: auto; }
  }
</style>
