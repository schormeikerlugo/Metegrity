---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/shared/PageHero.astro';
import ResourceCard from '../../components/shared/ResourceCard.astro';
import CTASection from '../../components/shared/CTASection.astro';

const papers = [
  { type: 'Whitepaper', title: 'Achieving Efficient Implementation of Asset Integrity Management', image: '/images/photos/wp-implement.jpg', meta: 'PDF · Free Download', tag: 'Implementation', href: '/insights/whitepapers/efficient-implementation' },
  { type: 'Whitepaper', title: 'How to Build a Business Case for Asset Integrity Management', image: '/images/photos/wp-business.jpg', meta: 'PDF · Free Download', tag: 'Business Case', href: '/insights/whitepapers/business-case' },
  { type: 'Whitepaper', title: 'Change Management Strategies for AIM', image: '/images/photos/wp-change.jpg', meta: 'PDF · Free Download', tag: 'Change Management', href: '/insights/whitepapers/change-management' },
];

const featured = {
  type: 'Featured Whitepaper',
  title: 'How to Defend the Merits of an Asset Integrity Management System',
  description: 'A practical guide for integrity professionals who need to justify AIM investments to leadership. Covers ROI frameworks, risk quantification, regulatory drivers, and real-world examples of how AIM systems deliver measurable value across operations.',
  image: '/images/photos/wp-defend.jpg',
  meta: '2025 · PDF · Free Download',
  tag: 'Featured',
  href: '/insights/whitepapers/defend-merits',
  featured: true,
};
---

<Layout title="Whitepapers | Metegrity" description="In-depth technical research and industry analysis from Metegrity's integrity experts.">
  <Navbar />
  <main>
    <PageHero
      eyebrow="Whitepapers"
      titleLight="Deep technical"
      titleBold="research & analysis."
      description="Rigorous industry research on risk-based inspection, corrosion management, regulatory compliance, and digital transformation — authored by our integrity engineers."
      align="center"
    />

    <!-- Featured -->
    <section class="wp-featured section">
      <div class="container">
        <ResourceCard {...featured} />
      </div>
    </section>

    <!-- Grid with inline download form -->
    <section class="wp-grid section">
      <div class="container">
        <div class="wp-grid__inner">
          <div class="wp-grid__list">
            <div class="wp-grid__header reveal">
              <div class="section-label">All Whitepapers</div>
              <h2>
                <span class="text-light">Browse our</span>
                <span class="text-bold">research library.</span>
              </h2>
            </div>
            <div class="wp-grid__items">
              {papers.map((p, i) => (
                <div class="wp-grid__item reveal" style={`transition-delay: ${(i % 2) * 60}ms`}>
                  <ResourceCard {...p} compact={true} />
                </div>
              ))}
            </div>
          </div>

          <!-- Sidebar subscribe -->
          <aside class="wp-sidebar">
            <div class="wp-sidebar__card">
              <h3>Never miss a paper</h3>
              <p>Get notified when we publish new research. No spam, just the good stuff.</p>
              <form class="wp-sidebar__form" onsubmit="event.preventDefault()">
                <input type="email" placeholder="your@email.com" required />
                <button type="submit" class="btn btn-primary">Subscribe</button>
              </form>
              <p class="wp-sidebar__note">Unsubscribe anytime. Read our privacy policy.</p>
            </div>

            <div class="wp-sidebar__topics">
              <h4>Topics</h4>
              <ul>
                <li><a href="#">RBI</a></li>
                <li><a href="#">Corrosion Management</a></li>
                <li><a href="#">Implementation</a></li>
                <li><a href="#">Business Case</a></li>
                <li><a href="#">Change Management</a></li>
              </ul>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <CTASection
      titleLight="Need specific"
      titleBold="research for your team?"
      description="Our integrity engineers can deliver custom research and white-label analysis tailored to your operational challenges."
      primaryLabel="Request Research"
    />
  </main>
  <Footer />
</Layout>

<style>
  .wp-featured :global(.rcard--featured) {
    max-width: 100%;
  }

  .wp-grid__inner {
    display: grid;
    grid-template-columns: 2.5fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .wp-grid__header {
    margin-bottom: var(--space-8);
  }

  .wp-grid__items {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  /* Sidebar */
  .wp-sidebar {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .wp-sidebar__card {
    padding: var(--space-6);
    background: var(--color-dark);
    color: var(--color-white);
    border-radius: var(--radius-xl);
  }

  .wp-sidebar__card h3 {
    font-size: var(--font-size-lg);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-2);
  }

  .wp-sidebar__card p {
    font-size: var(--font-size-sm);
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .wp-sidebar__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .wp-sidebar__form input {
    padding: var(--space-3) var(--space-4);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
  }

  .wp-sidebar__form input::placeholder { color: rgba(255,255,255,0.4); }

  .wp-sidebar__form input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .wp-sidebar__form button {
    width: 100%;
  }

  .wp-sidebar__note {
    font-size: 10px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0 !important;
  }

  .wp-sidebar__topics {
    padding: var(--space-6);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .wp-sidebar__topics h4 {
    font-size: var(--font-size-md);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin-bottom: var(--space-4);
  }

  .wp-sidebar__topics ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .wp-sidebar__topics a {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
    font-weight: var(--font-medium);
  }

  .wp-sidebar__topics a:hover { color: var(--color-primary); }

  @media (max-width: 1024px) {
    .wp-grid__inner { grid-template-columns: 1fr; }
    .wp-sidebar { position: static; flex-direction: row; gap: var(--space-5); }
    .wp-sidebar > * { flex: 1; }
  }

  @media (max-width: 768px) {
    .wp-grid__items { grid-template-columns: 1fr; }
    .wp-sidebar { flex-direction: column; }
    .wp-grid__header { text-align: center; }
  }
</style>
