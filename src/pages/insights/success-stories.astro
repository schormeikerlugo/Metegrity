---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/shared/PageHero.astro';
import ResourceCard from '../../components/shared/ResourceCard.astro';
import CTASection from '../../components/shared/CTASection.astro';
import FilterBar from '../../components/shared/FilterBar.astro';

const flagship = {
  type: 'Flagship Case Study',
  title: 'Enhancing Asset Integrity: How Metegrity Visions Enterprise Powers the Agbami FPSO\'s Reliability and Performance',
  description: 'Discover how the Agbami FPSO leverages Metegrity\'s Visions Enterprise platform to maintain world-class reliability and performance across its deepwater operations offshore Nigeria, managing thousands of equipment items with a comprehensive integrity program.',
  image: '/images/photos/cs-agbami.jpg',
  meta: 'Oil & Gas · Feb 2025',
  tag: 'Flagship',
  href: '/insights/success-stories/agbami-fpso',
  featured: true,
};

const stories = [
  { type: 'Success Story', title: 'Delivering Comprehensive AIM for MISC Mero 3 FPSO', image: '/images/photos/cs-misc.jpg', meta: 'Oil & Gas · Jan 2025', tag: 'Oil & Gas', href: '/insights/success-stories/misc-mero3' },
  { type: 'Success Story', title: 'Visions Enterprise Revolutionizes Facility Integrity for NA Energy Delivery Leader', image: '/images/photos/cs-energy.jpg', meta: 'Energy · Nov 2023', tag: 'Energy Delivery', href: '/insights/success-stories/energy-delivery' },
  { type: 'Success Story', title: 'MOL Group Chooses TUV Rheinland and Metegrity', image: '/images/photos/cs-mol.jpg', meta: 'Refining · Sep 2023', tag: 'Refining', href: '/insights/success-stories/mol-group' },
  { type: 'Success Story', title: 'Enhanced Asset Integrity Through Improved Data Management: Methanex', image: '/images/photos/cs-methanex.jpg', meta: 'Chemical · Jun 2023', tag: 'Chemical', href: '/insights/success-stories/methanex' },
  { type: 'Success Story', title: 'Nippon Chemical Chooses Metegrity for Inspections', image: '/images/photos/cs-nippon.jpg', meta: 'Chemical · May 2022', tag: 'Chemical', href: '/insights/success-stories/nippon-chemical' },
];

const filters = ['All', 'Oil & Gas', 'Chemical', 'Refining', 'Energy Delivery'];
---

<Layout title="Success Stories | Metegrity" description="Real-world case studies from 1,350+ Metegrity clients across oil & gas, chemical, and power industries.">
  <Navbar />
  <main>
    <PageHero
      eyebrow="Success Stories"
      titleLight="Real operators."
      titleBold="Real outcomes."
      description="Deep dives into how the world's most critical operations use Metegrity to reduce risk, optimize inspections, and keep production running safely."
      align="center"
    />

    <!-- Flagship -->
    <section class="ss-flagship section">
      <div class="container">
        <div class="ss-flagship__inner">
          <ResourceCard {...flagship} />
        </div>
      </div>
    </section>

    <!-- Grid -->
    <section class="ss-grid section">
      <div class="container">
        <div class="ss-grid__header reveal">
          <div class="section-label">All Stories</div>
          <h2>
            <span class="text-light">Browse by</span>
            <span class="text-bold">industry and use case.</span>
          </h2>
        </div>

        <FilterBar categories={filters} targetGrid=".ss-grid__list" />

        <div class="ss-grid__list">
          {stories.map((s) => (
            <div class="ss-grid__item" data-tag={s.tag}>
              <ResourceCard {...s} />
            </div>
          ))}
        </div>

        <div class="ss-grid__more reveal">
          <button class="btn btn-outline">Load More Stories</button>
        </div>
      </div>
    </section>

    <CTASection
      titleLight="Have a story"
      titleBold="worth telling?"
      description="We love showcasing our clients' successes. Let's collaborate on a case study that inspires the industry."
      primaryLabel="Share Your Story"
    />
  </main>
  <Footer />
</Layout>

<style>
  .ss-flagship__inner :global(.rcard--featured) {
    max-width: 100%;
  }

  .ss-grid__header {
    max-width: 640px;
    margin-bottom: var(--space-10);
  }

  .ss-grid__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    margin-bottom: var(--space-12);
  }

  .ss-grid__more {
    text-align: center;
  }

  @media (max-width: 900px) {
    .ss-grid__list { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .ss-grid__list { grid-template-columns: 1fr; }
    .ss-grid__header { text-align: center; margin-left: auto; margin-right: auto; }
  }
</style>
