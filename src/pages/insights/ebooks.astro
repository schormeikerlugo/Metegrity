---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/shared/PageHero.astro';
import CTASection from '../../components/shared/CTASection.astro';

const ebooks = [
  {
    title: 'The Ultimate Guide to Asset Integrity Management',
    description: 'A 120-page foundation text covering RBI, corrosion management, inspection planning, PSM compliance, and digital transformation. The most comprehensive AIM guide published.',
    pages: '120',
    rating: '4.9',
    downloads: '8.5K',
    image: '/images/photos/whitepaper.jpg',
    tag: 'Bestseller',
    featured: true,
  },
  {
    title: 'Risk-Based Inspection from Theory to Practice',
    description: 'Step-by-step implementation guide for RBI programs. Covers qualitative, semi-quantitative, and fully quantitative methodologies with real-world examples.',
    pages: '84', rating: '4.8', downloads: '5.2K',
    image: '/images/photos/research.jpg',
    tag: 'RBI',
  },
  {
    title: 'Corrosion Management Handbook',
    description: 'Damage mechanisms, monitoring strategies, and mitigation techniques across oil & gas, chemical, and power industries.',
    pages: '96', rating: '4.7', downloads: '4.1K',
    image: '/images/photos/corrosion.jpg',
    tag: 'Corrosion',
  },
  {
    title: 'PSM Mechanical Integrity Playbook',
    description: 'How to build and maintain an audit-ready mechanical integrity program that stands up to OSHA PSM scrutiny.',
    pages: '72', rating: '4.8', downloads: '3.8K',
    image: '/images/photos/chem-plant.jpg',
    tag: 'PSM',
  },
  {
    title: 'Digital Transformation in AIM',
    description: 'From legacy spreadsheets to modern integrity platforms — a practical transformation roadmap.',
    pages: '68', rating: '4.6', downloads: '3.2K',
    image: '/images/photos/data-analysis.jpg',
    tag: 'Digital',
  },
  {
    title: 'Offshore Integrity in Harsh Environments',
    description: 'Lessons from 30+ years of deepwater and Arctic operations. Includes FPSO, platform, and subsea integrity best practices.',
    pages: '88', rating: '4.9', downloads: '2.9K',
    image: '/images/photos/offshore.jpg',
    tag: 'Offshore',
  },
];
---

<Layout title="eBooks | Metegrity" description="Comprehensive guides for integrity professionals — 120+ pages of expertise, free to download.">
  <Navbar />
  <main>
    <PageHero
      eyebrow="eBooks"
      titleLight="Deep knowledge."
      titleBold="Free to download."
      description="Comprehensive guides on asset integrity management, written by our integrity engineers and refined over 30+ years of client engagements."
      align="center"
    />

    <!-- Stats -->
    <section class="eb-stats">
      <div class="container eb-stats__inner">
        <div class="eb-stats__item"><span>10+</span><label>eBooks Published</label></div>
        <div class="eb-stats__item"><span>700+</span><label>Pages of Content</label></div>
        <div class="eb-stats__item"><span>28K+</span><label>Total Downloads</label></div>
        <div class="eb-stats__item"><span>4.8/5</span><label>Average Rating</label></div>
      </div>
    </section>

    <!-- Featured -->
    <section class="eb-featured section">
      <div class="container">
        <article class="eb-feature reveal">
          <div class="eb-feature__cover">
            <div class="eb-feature__cover-inner">
              <img src={ebooks[0].image} alt={ebooks[0].title} loading="lazy" />
              <div class="eb-feature__spine"></div>
              <span class="eb-feature__pages">{ebooks[0].pages} pages</span>
            </div>
          </div>
          <div class="eb-feature__content">
            <span class="eb-feature__tag">{ebooks[0].tag}</span>
            <h2>{ebooks[0].title}</h2>
            <p>{ebooks[0].description}</p>
            <div class="eb-feature__meta">
              <div>
                <span class="eb-feature__meta-val">{ebooks[0].rating}</span>
                <span class="eb-feature__meta-lbl">★ Rating</span>
              </div>
              <div>
                <span class="eb-feature__meta-val">{ebooks[0].downloads}</span>
                <span class="eb-feature__meta-lbl">Downloads</span>
              </div>
              <div>
                <span class="eb-feature__meta-val">{ebooks[0].pages}</span>
                <span class="eb-feature__meta-lbl">Pages</span>
              </div>
            </div>
            <div class="eb-feature__cta">
              <a href="#" class="btn btn-primary">Download Free</a>
              <a href="#" class="btn btn-outline">Read Sample</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Library -->
    <section class="eb-library section">
      <div class="container">
        <div class="eb-library__header reveal">
          <div class="section-label">Complete Library</div>
          <h2>
            <span class="text-light">Browse all</span>
            <span class="text-bold">eBooks.</span>
          </h2>
        </div>

        <div class="eb-library__grid">
          {ebooks.slice(1).map((b, i) => (
            <a href="#" class="eb-card reveal" style={`transition-delay: ${(i % 3) * 80}ms`}>
              <div class="eb-card__cover">
                <img src={b.image} alt={b.title} loading="lazy" />
                <span class="eb-card__tag">{b.tag}</span>
              </div>
              <div class="eb-card__content">
                <h3>{b.title}</h3>
                <p>{b.description}</p>
                <div class="eb-card__meta">
                  <span>{b.pages} pages</span>
                  <span class="eb-card__sep">·</span>
                  <span>★ {b.rating}</span>
                  <span class="eb-card__sep">·</span>
                  <span>{b.downloads} downloads</span>
                </div>
                <div class="eb-card__cta">
                  <span>Download</span>
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <path d="M8 2v10M4 8l4 4 4-4M3 14h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTASection
      titleLight="Want custom content"
      titleBold="for your team?"
      description="We author white-label eBooks and training materials tailored to your operational context. Contact our research team."
      primaryLabel="Request Custom Content"
    />
  </main>
  <Footer />
</Layout>

<style>
  .eb-stats {
    background: var(--color-dark);
    color: var(--color-white);
    padding: var(--space-12) 0;
  }

  .eb-stats__inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    text-align: center;
  }

  .eb-stats__item span {
    display: block;
    font-size: var(--font-size-4xl);
    font-weight: var(--font-extrabold);
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
  }

  .eb-stats__item label {
    font-size: var(--font-size-xs);
    color: rgba(255,255,255,0.6);
    font-weight: var(--font-medium);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Featured eBook */
  .eb-feature {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-12);
    align-items: center;
  }

  .eb-feature__cover {
    display: flex;
    justify-content: center;
    perspective: 1200px;
  }

  .eb-feature__cover-inner {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 3 / 4;
    transform: rotateY(-8deg);
    transform-style: preserve-3d;
    transition: transform var(--transition-slow);
    box-shadow: 30px 40px 80px rgba(0,0,0,0.25), 10px 10px 30px rgba(0,0,0,0.15);
    border-radius: var(--radius-sm) var(--radius-md) var(--radius-md) var(--radius-sm);
    overflow: hidden;
  }

  .eb-feature__cover:hover .eb-feature__cover-inner {
    transform: rotateY(-2deg) translateY(-4px);
  }

  .eb-feature__cover-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .eb-feature__spine {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 14px;
    background: linear-gradient(90deg, rgba(0,0,0,0.4), rgba(0,0,0,0.1), transparent);
  }

  .eb-feature__pages {
    position: absolute;
    bottom: var(--space-4);
    right: var(--space-4);
    padding: 4px 10px;
    background: rgba(255,255,255,0.9);
    color: var(--color-dark);
    font-size: 10px;
    font-weight: var(--font-bold);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .eb-feature__tag {
    display: inline-block;
    padding: 4px 10px;
    background: rgba(255, 107, 0, 0.12);
    color: var(--color-primary);
    font-size: 10px;
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-4);
  }

  .eb-feature__content h2 {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-bold);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-5);
  }

  .eb-feature__content p {
    font-size: var(--font-size-md);
    line-height: 1.7;
    margin-bottom: var(--space-6);
    max-width: 560px;
  }

  .eb-feature__meta {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: var(--space-8);
    margin-bottom: var(--space-6);
    padding: var(--space-4) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    justify-content: flex-start;
  }

  .eb-feature__meta-val {
    display: block;
    font-size: var(--font-size-xl);
    font-weight: var(--font-extrabold);
    color: var(--color-dark);
    line-height: 1;
  }

  .eb-feature__meta-lbl {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: var(--space-1);
    display: block;
  }

  .eb-feature__cta {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* Library grid */
  .eb-library {
    background: var(--color-bg-alt);
  }

  .eb-library__header {
    max-width: 640px;
    margin-bottom: var(--space-10);
  }

  .eb-library__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .eb-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
  }

  .eb-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    border-color: rgba(255, 107, 0, 0.25);
  }

  .eb-card__cover {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .eb-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 6s ease;
  }

  .eb-card:hover .eb-card__cover img { transform: scale(1.06); }

  .eb-card__tag {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    padding: 4px 10px;
    background: rgba(255, 255, 255, 0.92);
    font-size: 10px;
    font-weight: var(--font-bold);
    color: var(--color-dark);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .eb-card__content {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .eb-card__content h3 {
    font-size: var(--font-size-lg);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    line-height: 1.3;
  }

  .eb-card__content p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    flex: 1;
  }

  .eb-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    font-weight: var(--font-medium);
  }

  .eb-card__sep { opacity: 0.4; }

  .eb-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    margin-top: var(--space-2);
  }

  .eb-card:hover .eb-card__cta { gap: var(--space-3); }

  @media (max-width: 900px) {
    .eb-feature { grid-template-columns: 1fr; text-align: center; }
    .eb-feature__cover-inner { transform: rotateY(0); }
    .eb-feature__meta { justify-content: center; }
    .eb-feature__cta { justify-content: center; }
    .eb-feature__content p { margin-left: auto; margin-right: auto; }
    .eb-library__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .eb-stats__inner { grid-template-columns: repeat(2, 1fr); gap: var(--space-8); }
    .eb-stats__item span { font-size: var(--font-size-3xl); }
  }

  @media (max-width: 560px) {
    .eb-library__grid { grid-template-columns: 1fr; }
    .eb-library__header { text-align: center; margin-left: auto; margin-right: auto; }
    .eb-feature__meta { grid-template-columns: repeat(3, 1fr); gap: var(--space-3); }
  }
</style>
